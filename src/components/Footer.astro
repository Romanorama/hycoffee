---

---

<footer class="footer">
  <div class="footer-inner">
    <!-- Top: Logo + Newsletter + Contact -->
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/images/logo-light.svg" alt="HyCoffee" class="footer-logo" width="169" height="40" loading="lazy" decoding="async" />
        <p class="footer-tagline">Klimaresiliente Kaffeebohnen</p>
      </div>
      <div class="footer-newsletter">
        <p class="newsletter-label">Signup for our Newsletter and join the growing community.</p>
        <div class="newsletter-form">
          <input type="email" placeholder="Enter your email" class="newsletter-input" />
          <button class="btn-newsletter">
            <span>Anmelden</span>
            <svg width="14" height="11" viewBox="0 0 14 11" fill="none">
              <path d="M1 5.5h12m0 0L8.5 1M13 5.5L8.5 10" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="footer-contact">
        <a href="tel:+41000000000" class="footer-contact-link">+41 00 000 00 00</a>
        <a href="mailto:info@hycoffee.com" class="footer-contact-link">info@hycoffee.com</a>
      </div>
    </div>

    <div class="footer-divider"></div>

    <!-- Middle: 4 columns -->
    <div class="footer-columns">
      <div class="footer-col">
        <h4 class="footer-col-title">About us</h4>
        <p class="footer-col-text">Wir erforschen, entwickeln und liefern klimaresilienten Rohkaffee für eine nachhaltige Zukunft.</p>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">Navigation</h4>
        <a href="/" class="footer-col-link">Home</a>
        <a href="/kaffee" class="footer-col-link">Kaffee kaufen</a>
        <a href="/wissen" class="footer-col-link">Wissen</a>
        <a href="/ueber-uns" class="footer-col-link">Über Uns</a>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">Adresse</h4>
        <p class="footer-col-text">HyCoffee UG (haftungsbeschränkt)</p>
        <p class="footer-col-text">Tassilostraße 15</p>
        <p class="footer-col-text">82166 Gräfelfing</p>
        <p class="footer-col-text">Deutschland</p>
      </div>
      <div class="footer-col">
        <h4 class="footer-col-title">Follow Us</h4>
        <a href="https://www.instagram.com/hycoffeeco/" target="_blank" rel="noopener noreferrer" class="footer-col-link">Instagram</a>
        <a href="https://de.linkedin.com/company/hycoffee" target="_blank" rel="noopener noreferrer" class="footer-col-link">LinkedIn</a>
      </div>
    </div>

    <div class="footer-divider"></div>

    <!-- Bottom: Copyright + Legal -->
    <div class="footer-bottom">
      <p class="footer-copyright">© 2026 HyCoffee. All rights reserved.</p>
      <div class="footer-legal">
        <a href="/impressum" class="footer-legal-link">Impressum</a>
        <a href="/datenschutz" class="footer-legal-link">Datenschutz</a>
        <a href="/agb" class="footer-legal-link">AGB</a>
      </div>
    </div>
  </div>
</footer>

<footer class="footer-alt" aria-label="Alternative Footer">
  <section class="footer-alt-newsletter" aria-label="Newsletter">
    <h2 class="footer-alt-newsletter-title">HyC monthly Newsletter</h2>
    <form class="footer-alt-form">
      <input type="email" placeholder="Email" class="footer-alt-input" aria-label="Email" />
      <button type="submit" class="footer-alt-submit" aria-label="Newsletter abonnieren">
        <span>Anmelden</span>
      </button>
    </form>
    <p class="footer-alt-newsletter-copy">Join the growing community</p>
  </section>

  <section class="footer-alt-main">
    <div class="footer-alt-brand" aria-hidden="true">
      <img src="/images/inv-Hy-mono.svg" alt="" class="footer-alt-logo" width="455" height="316" loading="lazy" decoding="async" />
    </div>
    <p class="footer-alt-tagline">Klimaresiliente Kaffeebohnen</p>

    <div class="footer-alt-content">
      <div class="footer-alt-col footer-alt-contact">
        <h3 class="footer-alt-label">Kontakt</h3>
        <a href="mailto:info@hycoffee.com" class="footer-alt-link footer-alt-mono">info@hycoffee.com</a>
        <a href="tel:+4901571234556" class="footer-alt-link footer-alt-mono">0049 (0) 157123 45 56</a>

        <address class="footer-alt-address">
          HyCoffee UG<br />
          (haftungsbeschränkt)<br />
          Tassilostraße 15<br />
          82166 Gräfelfing<br />
          Deutschland
        </address>
      </div>

      <nav class="footer-alt-col" aria-label="Footer Navigation">
        <h3 class="footer-alt-label">Navigation</h3>
        <a href="/" class="footer-alt-link">Home</a>
        <a href="/kaffee" class="footer-alt-link">Kaffee kaufen</a>
        <a href="/wissen" class="footer-alt-link">Wissen</a>
        <a href="/ueber-uns" class="footer-alt-link">Über Uns</a>
        <div class="footer-alt-nav-legal">
          <a href="/agb" class="footer-alt-legal-link">AGB</a>
          <a href="/datenschutz" class="footer-alt-legal-link">Datenschutz</a>
          <a href="/impressum" class="footer-alt-legal-link">Impressum</a>
        </div>
      </nav>

      <div class="footer-alt-col">
        <h3 class="footer-alt-label">Folge uns</h3>
        <a href="https://www.instagram.com/hycoffeeco/" target="_blank" rel="noopener noreferrer" class="footer-alt-link">Instagram</a>
        <a href="https://de.linkedin.com/company/hycoffee" target="_blank" rel="noopener noreferrer" class="footer-alt-link">LinkedIn</a>
      </div>
    </div>
    <p class="footer-alt-copyright">© 2026 HyCoffee. All rights reserved.</p>
  </section>
</footer>

<div id="footer-version-switcher" class="footer-version-switcher" aria-label="Footer-Version wechseln">
  <button type="button" class="footer-version-option" data-footer-version="classic">Footer A</button>
  <button type="button" class="footer-version-option" data-footer-version="alt">Footer B</button>
</div>

<style>
  .footer {
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 60px 60px 40px;
  }

  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  :global(body.footer-alt-active) .footer {
    display: none;
  }

  .footer-alt {
    display: none;
    --footer-alt-pad: 69px;
    --footer-alt-edge: 12px;
    --footer-alt-gap: clamp(12px, 1.2vw, 24px);
    --footer-alt-logo-bleed: clamp(54px, 7vw, 132px);
    --footer-alt-cols: repeat(4, minmax(0, 1fr));
  }

  :global(body.footer-alt-active) .footer-alt {
    display: block;
  }

  .footer-version-switcher {
    position: fixed;
    right: 12px;
    bottom: 12px;
    z-index: 290;
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    font-family: var(--font-ui);
    font-size: var(--type-control-tiny);
    letter-spacing: 1.1px;
    text-transform: uppercase;
    background: rgba(36, 33, 25, 0.75);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius-pill);
  }

  .footer-version-option {
    min-width: 70px;
    padding: 6px 9px 4px;
    border-radius: var(--radius-pill);
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--font-ui);
    font-size: var(--type-control-tiny);
    letter-spacing: 1.1px;
    text-transform: uppercase;
  }

  .footer-version-option.is-active {
    background: var(--white);
    color: var(--warm-dark-grey);
  }

  .footer-alt-newsletter {
    --footer-alt-newsletter-control-type: clamp(19px, 0.56vw + 14px, 24px);
    display: grid;
    grid-template-columns: var(--footer-alt-cols);
    gap: var(--footer-alt-gap);
    align-items: center;
    padding: 52px var(--footer-alt-pad);
    background: var(--warm-grey-light);
    color: var(--warm-dark-grey);
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .footer-alt-newsletter-title,
  .footer-alt-newsletter-copy {
    font-family: var(--font-heading);
    font-size: clamp(18px, 0.65vw + 12px, 24px);
    line-height: 1.08;
    letter-spacing: 0;
    font-weight: 400;
  }

  .footer-alt-newsletter-title {
    justify-self: start;
    text-align: left;
  }

  .footer-alt-newsletter-copy {
    justify-self: start;
    text-align: left;
  }

  .footer-alt-form {
    grid-column: 2 / 4;
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(104px, 1fr);
    column-gap: 8px;
    align-items: center;
    min-height: 52px;
    background: transparent;
  }

  .footer-alt-input {
    width: 100%;
    height: 100%;
    min-height: 50px;
    border: 1px solid rgba(36, 33, 25, 0.62);
    border-radius: var(--radius-media);
    background: transparent;
    padding: 4px 22px 0;
    font-family: var(--font-ui);
    font-size: var(--footer-alt-newsletter-control-type);
    line-height: 1;
    letter-spacing: 0.5px;
    color: var(--warm-dark-grey);
    outline: none;
  }

  .footer-alt-input::placeholder {
    color: rgba(36, 33, 25, 0.44);
  }

  .footer-alt-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    justify-self: stretch;
    align-self: stretch;
    min-height: 36px;
    margin: 0;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    font-family: var(--font-ui);
    font-size: var(--footer-alt-newsletter-control-type);
    letter-spacing: 0.5px;
    line-height: 1;
    border-radius: var(--radius-media);
    padding: 0 20px;
    transition: filter 0.2s ease, transform 0.2s ease;
  }

  .footer-alt-submit span {
    transform: translateY(2px);
  }

  .footer-alt-submit:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .footer-alt-main {
    position: relative;
    display: grid;
    grid-template-columns: var(--footer-alt-cols);
    gap: var(--footer-alt-gap);
    align-items: start;
    min-height: 548px;
    overflow: hidden;
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 150px var(--footer-alt-pad) 44px;
  }

  .footer-alt-brand {
    position: relative;
    grid-column: 1;
    align-self: start;
    z-index: 0;
    width: calc(100% + var(--footer-alt-logo-bleed));
    max-width: none;
    min-width: 0;
    margin-top: -118px;
    margin-left: calc(-1 * var(--footer-alt-logo-bleed));
    overflow: hidden;
    pointer-events: none;
  }

  .footer-alt-logo {
    width: 100%;
    max-width: none;
    height: auto;
    display: block;
  }

  .footer-alt-tagline {
    position: absolute;
    left: var(--footer-alt-edge);
    bottom: var(--footer-alt-edge);
    width: max-content;
    z-index: 2;
    font-family: var(--font-ui);
    font-size: var(--type-button);
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .footer-alt-content {
    display: contents;
  }

  .footer-alt-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    z-index: 1;
  }

  .footer-alt-label {
    margin-bottom: 26px;
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 400;
  }

  .footer-alt-link,
  .footer-alt-address {
    font-size: clamp(14px, 0.63vw + 9px, 21px);
    line-height: 1.45;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.82);
    font-style: normal;
  }

  .footer-alt-link {
    font-family: var(--font-ui);
  }

  .footer-alt-contact .footer-alt-link,
  .footer-alt-address {
    font-family: var(--font-heading);
  }

  .footer-alt-link {
    transition: color 0.2s, opacity 0.2s;
  }

  .footer-alt-link:hover {
    color: var(--white);
  }

  .footer-alt-mono {
    line-height: 1.15;
  }

  .footer-alt-address {
    margin-top: 42px;
    max-width: 360px;
    color: rgba(255, 255, 255, 0.82);
  }

  .footer-alt-nav-legal {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 48px;
  }

  .footer-alt-copyright {
    position: absolute;
    right: var(--footer-alt-pad);
    bottom: var(--footer-alt-edge);
    z-index: 2;
    font-family: var(--font-ui);
    font-size: var(--type-copy-sm);
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.42);
  }

  .footer-alt-legal-link {
    font-family: var(--font-ui);
    font-size: clamp(13px, 0.5vw + 8px, 18px);
    line-height: 1.15;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.42);
    transition: color 0.2s;
  }

  .footer-alt-legal-link:hover {
    color: var(--white);
  }

  @media (max-width: 1180px) {
    .footer-alt {
      --footer-alt-gap: 36px;
      --footer-alt-logo-bleed: clamp(44px, 6vw, 88px);
    }

    .footer-alt-newsletter {
      grid-template-columns: 1fr;
      gap: 24px;
      padding-block: 42px;
    }

    .footer-alt-newsletter-copy {
      justify-self: start;
      text-align: left;
    }

    .footer-alt-form {
      grid-column: auto;
      width: 100%;
    }

    .footer-alt-main {
      padding-top: 96px;
    }

    .footer-alt-brand {
      opacity: 0.34;
    }

    .footer-alt-content {
      display: contents;
    }
  }

  /* Top */
  .footer-top {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    align-items: start;
    padding-bottom: 48px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .footer-logo {
    height: 40px;
    max-width: 100%;
    object-fit: contain;
    object-position: left;
    justify-self: start;
  }

  .footer-tagline {
    font-family: var(--font-ui);
    font-size: var(--type-copy-sm);
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.45);
  }

  .footer-newsletter {
    grid-column: 2 / 4;
    width: 100%;
    justify-self: start;
  }

  .newsletter-label {
    font-family: var(--font-ui);
    font-size: var(--type-copy-sm);
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 10px;
  }

  .newsletter-form {
    display: flex;
    align-items: center;
    background: var(--warm-grey-light);
    border-radius: var(--radius-media);
    padding: 4px 4px 4px 16px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
  }

  .newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-ui);
    font-size: var(--type-copy);
    letter-spacing: 0.5px;
    color: var(--warm-dark-grey);
    padding: 10px 0;
  }

  .newsletter-input::placeholder {
    color: rgba(36, 33, 25, 0.45);
  }

  .btn-newsletter {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 42px;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    padding: 0 20px;
    border-radius: var(--radius-nested);
    font-family: var(--font-ui);
    font-size: var(--type-button);
    line-height: 1;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: filter 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
    border: none;
  }

  .btn-newsletter span {
    transform: translateY(1px);
  }

  .btn-newsletter:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }

  .footer-contact-link {
    font-family: var(--font-ui);
    font-size: var(--type-copy);
    letter-spacing: 0.5px;
    color: var(--white);
    transition: opacity 0.2s;
  }

  .footer-contact-link:hover {
    opacity: 0.7;
  }

  /* Divider */
  .footer-divider {
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.08), rgba(255,255,255,0.2), rgba(255,255,255,0.08));
  }

  /* Columns */
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding: 48px 0;
  }

  .footer-col-title {
    font-family: var(--font-ui);
    font-size: var(--type-copy);
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--white);
    margin-bottom: 16px;
  }

  .footer-col-text {
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy);
    letter-spacing: 0.5px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-col-link {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--type-copy);
    letter-spacing: 0.5px;
    line-height: 2;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s;
  }

  .footer-col-link:hover {
    color: var(--white);
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 48px;
  }

  .footer-copyright {
    font-family: var(--font-ui);
    font-size: var(--type-copy-sm);
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.35);
  }

  .footer-legal {
    display: flex;
    gap: 28px;
  }

  .footer-legal-link {
    font-family: var(--font-ui);
    font-size: var(--type-copy-sm);
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.2s;
  }

  .footer-legal-link:hover {
    color: var(--white);
  }

  @media (max-width: 900px) {
    .footer-alt {
      --footer-alt-pad: 16px;
      --footer-alt-edge: 16px;
      --footer-alt-logo-bleed: clamp(64px, 18vw, 120px);
      --footer-alt-cols: 1fr;
    }

    .footer {
      padding: 40px 24px 32px;
    }

    .footer-top {
      grid-template-columns: 1fr;
      gap: 24px;
      padding-bottom: 32px;
    }

    .footer-newsletter {
      width: 100%;
      justify-self: stretch;
    }

    .footer-contact {
      align-items: flex-start;
    }

    .footer-columns {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      padding: 32px 0;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 12px;
      align-items: flex-start;
      padding-top: 32px;
    }

    .footer-alt-newsletter {
      padding: 36px var(--footer-alt-pad);
      justify-items: start;
      text-align: left;
    }

    .footer-alt-newsletter-title,
    .footer-alt-newsletter-copy {
      justify-self: start;
      text-align: left;
    }

    .footer-alt-form {
      grid-template-columns: 1fr auto;
      min-height: 74px;
      width: 100%;
    }

    .footer-alt-input {
      min-height: 72px;
      padding-inline: 18px;
      text-align: center;
    }

    .footer-alt-submit {
      min-height: 52px;
      margin: 10px 10px 10px 0;
      padding: 0 18px;
      font-size: var(--footer-alt-newsletter-control-type);
    }

    .footer-alt-main {
      display: grid;
      grid-template-columns: 1fr;
      min-height: 0;
      padding: 52px 24px 32px;
    }

    .footer-alt-brand {
      width: min(calc(140% + var(--footer-alt-logo-bleed)), 540px);
      opacity: 1;
      margin: -80px 0 24px calc(-1 * var(--footer-alt-logo-bleed));
    }

    .footer-alt-tagline {
      position: static;
      justify-self: center;
      width: 100%;
      margin: 8px auto 0;
      font-size: var(--type-caption-sm);
      text-align: center;
    }

    .footer-alt-content {
      display: contents;
    }

    .footer-alt-col {
      align-items: center;
      text-align: center;
    }

    .footer-alt-label {
      margin-bottom: 14px;
      font-size: var(--type-caption-sm);
    }

    .footer-alt-link,
    .footer-alt-address {
      font-size: var(--type-button);
      line-height: 1.55;
    }

    .footer-alt-address {
      margin-top: 28px;
      max-width: 320px;
    }

    .footer-alt-copyright {
      position: static;
      padding: 0 24px 32px;
      margin-top: 0;
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding: 0;
    }

    .footer-inner {
      display: flex;
      flex-direction: column;
    }

    /* Top: reorder — tagline, newsletter, then logo — all left-aligned */
    .footer-top {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: 0 24px;
    }

    .footer-brand {
      order: 2;
      align-items: flex-start;
      padding: 24px 0 32px;
    }

    .footer-tagline {
      order: 0;
      padding: 32px 0 0;
      font-size: var(--type-caption-sm);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: rgba(255, 255, 255, 0.35);
    }

    .footer-logo {
      height: 36px;
    }

    .footer-newsletter {
      order: 1;
      width: 100%;
      grid-column: unset;
      padding: 20px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .newsletter-label {
