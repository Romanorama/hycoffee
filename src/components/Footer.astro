---
import { reader } from '../lib/cms';
import { DEFAULT_LANG, getNavPath, ui, type Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? DEFAULT_LANG;
const copy = ui[lang];

const global = await reader.singletons.global.read();
const email = global?.email ?? '';
const phone = global?.phone ?? '';
const address = global?.address ?? '';
const instagramUrl = global?.instagramUrl ?? '';
const linkedinUrl = global?.linkedinUrl ?? '';
const globalContent = lang === 'en' ? (global?.contentEn ?? global?.contentDe) : global?.contentDe;
const fallbackGlobalContent = global?.contentDe;
const footerTagline = globalContent?.footerTagline ?? fallbackGlobalContent?.footerTagline ?? '';
const newsletterButton = globalContent?.newsletterButton ?? fallbackGlobalContent?.newsletterButton ?? '';
const offerListRecipient = 'info@hycoffee.de';
const offerListSubject = lang === 'en' ? 'Offer list request' : 'Angebotsliste anfragen';
const offerListBodyIntro = lang === 'en' ? 'Please send offer lists to:' : 'Bitte Angebotsliste an folgende E-Mail-Adresse senden:';
const telHref = phone.replace(/[^+\d]/g, '');
---

<footer class="site-footer footer-alt" aria-label="Footer">
  <section class="footer-alt-newsletter" aria-label="HyCoffee News">
    <form
      class="footer-alt-form"
      name="offer-list-request"
      method="POST"
      action={`mailto:${offerListRecipient}?subject=${encodeURIComponent(offerListSubject)}`}
      enctype="text/plain"
      data-offer-list-form
      data-recipient={offerListRecipient}
      data-subject={offerListSubject}
      data-body-intro={offerListBodyIntro}
    >
      <input type="email" name="email" placeholder="Email" class="footer-alt-input" aria-label="Email" required />
      <button type="submit" class="footer-alt-submit" aria-label={copy.footer.subscribeLabel}>
        <span>{newsletterButton}</span>
      </button>
    </form>
    <p class="footer-alt-newsletter-copy">{copy.footer.newsletterCopy}</p>
  </section>

  <section class="footer-alt-main">
    <div class="footer-alt-brand">
      <img src="/images/inv-Hy-mono.svg" alt="" class="footer-alt-logo" width="455" height="316" loading="lazy" decoding="async" />
      <p class="footer-alt-tagline">{footerTagline}</p>
    </div>

    <div class="footer-alt-content">
      <div class="footer-alt-col footer-alt-contact">
        <h3 class="footer-alt-label">{copy.footer.contact}</h3>
        <a href={`mailto:${email}`} class="footer-alt-link footer-alt-mono">{email}</a>
        <a href={`tel:${telHref}`} class="footer-alt-link footer-alt-mono">{phone}</a>

        <address class="footer-alt-address">{address}</address>
      </div>

      <nav class="footer-alt-col" aria-label="Footer Navigation">
        <h3 class="footer-alt-label">{copy.footer.navigation}</h3>
        <a href={getNavPath('home', lang)} class="footer-alt-link">{copy.nav.home}</a>
        <a href={getNavPath('coffee', lang)} class="footer-alt-link">{copy.nav.coffee}</a>
        <a href={getNavPath('knowledge', lang)} class="footer-alt-link">{copy.nav.knowledge}</a>
        <a href={getNavPath('about', lang)} class="footer-alt-link">{copy.nav.about}</a>
        <div class="footer-alt-nav-legal">
          <a href="/agb" class="footer-alt-legal-link">AGB</a>
          <a href="/datenschutz" class="footer-alt-legal-link">Datenschutz</a>
          <a href="/impressum" class="footer-alt-legal-link">Impressum</a>
        </div>
      </nav>

      <div class="footer-alt-col">
        <h3 class="footer-alt-label">{copy.footer.follow}</h3>
        {instagramUrl && <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="footer-alt-link">Instagram</a>}
        {linkedinUrl && <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="footer-alt-link">LinkedIn</a>}
      </div>
    </div>
    <p class="footer-alt-copyright">© 2026 HyCoffee. {copy.footer.rights}</p>
  </section>
</footer>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-offer-list-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
      if (!emailInput || !emailInput.reportValidity()) {
        return;
      }

      const recipient = form.dataset.recipient ?? 'info@hycoffee.de';
      const subject = form.dataset.subject ?? 'Angebotsliste anfragen';
      const bodyIntro = form.dataset.bodyIntro ?? 'Bitte Angebotsliste an folgende E-Mail-Adresse senden:';
      const body = `${bodyIntro}\n\n${emailInput.value}`;

      window.location.href = `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  });
</script>

<style>
  .site-footer {
    --footer-alt-pad: 69px;
    --footer-alt-edge: 12px;
    --footer-alt-gap: clamp(12px, 1.2vw, 24px);
    --footer-alt-logo-bleed: clamp(54px, 7vw, 132px);
    --footer-alt-cols: repeat(4, minmax(0, 1fr));
    display: block !important;
    background: var(--warm-dark-grey);
    color: var(--white);
  }

  .footer-alt-newsletter {
    --footer-alt-newsletter-control-type: clamp(19px, 0.56vw + 14px, 24px);
    --footer-alt-newsletter-button-type: clamp(16px, 0.36vw + 12px, 19px);
    display: grid;
    grid-template-columns: var(--footer-alt-cols);
    gap: var(--footer-alt-gap);
    align-items: center;
    padding: 52px var(--footer-alt-pad);
    background: var(--warm-dark-grey);
    color: var(--white);
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .footer-alt-newsletter-title,
  .footer-alt-newsletter-copy {
    font-family: var(--font-heading);
    font-size: clamp(18px, 0.65vw + 12px, 24px);
    line-height: 1.08;
    letter-spacing: 0;
    font-weight: 400;
    color: var(--white);
  }

  .footer-alt-newsletter-title {
    justify-self: start;
    text-align: left;
  }

  .footer-alt-newsletter-copy {
    justify-self: start;
    text-align: left;
  }

  .footer-alt-form {
    grid-column: 2 / 4;
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(104px, 1fr);
    column-gap: 8px;
    align-items: center;
    min-height: 52px;
    background: transparent;
  }

  .footer-alt-input {
    width: 100%;
    height: 100%;
    min-height: 50px;
    border: 1px solid var(--white);
    border-radius: var(--radius-media);
    background: var(--white);
    padding: 4px 22px 0;
    font-family: var(--font-ui);
    font-size: var(--footer-alt-newsletter-control-type);
    line-height: 1;
    letter-spacing: 0.5px;
    color: var(--warm-dark-grey);
    outline: none;
  }

  .footer-alt-input::placeholder {
    color: rgba(36, 33, 25, 0.44);
  }

  .footer-alt-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    justify-self: stretch;
    align-self: stretch;
    min-height: 36px;
    margin: 0;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    font-family: var(--font-ui);
    font-size: var(--footer-alt-newsletter-button-type);
    letter-spacing: 0.5px;
    line-height: 1;
    border-radius: var(--radius-media);
    padding: 0 20px;
    transition: filter 0.2s ease, transform 0.2s ease;
  }

  .footer-alt-submit span {
    transform: translateY(2px);
  }

  .footer-alt-submit:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .footer-alt-main {
    position: relative;
    display: grid;
    grid-template-columns: var(--footer-alt-cols);
    gap: var(--footer-alt-gap);
    align-items: start;
    min-height: 548px;
    overflow: hidden;
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 150px var(--footer-alt-pad) 44px;
  }

  .footer-alt-brand {
    position: relative;
    grid-column: 1;
    align-self: start;
    z-index: 0;
    width: calc(100% + var(--footer-alt-logo-bleed));
    max-width: none;
    min-width: 0;
    margin-top: -118px;
    margin-left: calc(-1 * var(--footer-alt-logo-bleed));
    overflow: visible;
    pointer-events: none;
  }

  .footer-alt-logo {
    width: 100%;
    max-width: none;
    height: auto;
    display: block;
  }

  .footer-alt-tagline {
    position: absolute;
    left: calc(var(--footer-alt-logo-bleed) - var(--footer-alt-pad) + var(--footer-alt-edge));
    bottom: -38px;
    width: max-content;
    z-index: 2;
    font-family: var(--font-ui);
    font-size: var(--type-button);
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .footer-alt-content {
    display: contents;
  }

  .footer-alt-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    z-index: 1;
  }

  .footer-alt-label {
    margin-bottom: 26px;
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 400;
  }

  .footer-alt-link,
  .footer-alt-address {
    font-size: clamp(14px, 0.63vw + 9px, 21px);
    line-height: 1.45;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.82);
    font-style: normal;
  }

  .footer-alt-link {
    font-family: var(--font-ui);
    transition: color 0.2s, opacity 0.2s;
  }

  .footer-alt-contact .footer-alt-link,
  .footer-alt-address {
    font-family: var(--font-heading);
  }

  .footer-alt-link:hover {
    color: var(--white);
  }

  .footer-alt-mono {
    line-height: 1.15;
  }

  .footer-alt-address {
    margin-top: 42px;
    max-width: 360px;
    white-space: pre-line;
  }

  .footer-alt-nav-legal {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 48px;
  }

  .footer-alt-copyright {
    position: absolute;
    right: var(--footer-alt-pad);
    bottom: var(--footer-alt-edge);
    z-index: 2;
    font-family: var(--font-ui);
    font-size: var(--type-copy-sm);
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.42);
  }

  .footer-alt-legal-link {
    font-family: var(--font-ui);
    font-size: clamp(13px, 0.5vw + 8px, 18px);
    line-height: 1.15;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.42);
    transition: color 0.2s;
  }

  .footer-alt-legal-link:hover {
    color: var(--white);
  }

  @media (max-width: 1180px) {
    .site-footer {
      --footer-alt-gap: 36px;
      --footer-alt-logo-bleed: clamp(44px, 6vw, 88px);
    }

    .footer-alt-newsletter {
      grid-template-columns: 1fr;
      gap: 24px;
      padding-block: 42px;
    }

    .footer-alt-newsletter-copy {
      justify-self: start;
      text-align: left;
    }

    .footer-alt-form {
      grid-column: auto;
      width: 100%;
    }

    .footer-alt-main {
      padding-top: 96px;
    }

    .footer-alt-brand {
      opacity: 1;
    }

    .footer-alt-content {
      display: contents;
    }
  }

  @media (max-width: 900px) {
    .site-footer {
      --footer-alt-pad: 16px;
      --footer-alt-edge: 16px;
      --footer-alt-logo-bleed: clamp(64px, 18vw, 120px);
      --footer-alt-cols: 1fr;
    }

    .footer-alt-newsletter {
      padding: 36px var(--footer-alt-pad);
      justify-items: start;
      text-align: left;
    }

    .footer-alt-newsletter-title,
    .footer-alt-newsletter-copy {
      justify-self: start;
      text-align: left;
    }

    .footer-alt-form {
      grid-template-columns: 1fr auto;
      min-height: 74px;
      width: 100%;
    }

    .footer-alt-input {
      min-height: 72px;
      padding-inline: 18px;
      text-align: center;
    }

    .footer-alt-submit {
      min-height: 52px;
      margin: 10px 10px 10px 0;
      padding: 0 18px;
      font-size: var(--footer-alt-newsletter-button-type);
    }

    .footer-alt-main {
      display: grid;
      grid-template-columns: 1fr;
      min-height: 0;
      padding: 52px 24px 32px;
    }

    .footer-alt-brand {
      width: min(calc(140% + var(--footer-alt-logo-bleed)), 540px);
      opacity: 1;
      margin: -80px 0 24px calc(-1 * var(--footer-alt-logo-bleed));
    }

    .footer-alt-tagline {
      position: static;
      justify-self: center;
      width: 100%;
      margin: 8px auto 0;
      font-size: var(--type-caption-sm);
      text-align: center;
    }

    .footer-alt-content {
      display: contents;
    }

    .footer-alt-col {
      align-items: center;
      text-align: center;
    }

    .footer-alt-label {
      margin-bottom: 14px;
      font-size: var(--type-caption-sm);
    }

    .footer-alt-link,
    .footer-alt-address {
      font-size: var(--type-button);
      line-height: 1.55;
    }

    .footer-alt-address {
      margin-top: 28px;
      max-width: 320px;
    }

    .footer-alt-copyright {
      position: static;
      padding: 0 24px 32px;
      margin-top: 0;
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .footer-alt-form {
      grid-template-columns: 1fr;
      row-gap: 8px;
    }

    .footer-alt-input {
      min-height: 58px;
      font-size: var(--footer-alt-newsletter-control-type);
    }

    .footer-alt-submit {
      min-height: 56px;
      margin: 0;
      width: 100%;
      font-size: var(--footer-alt-newsletter-button-type);
    }

    .footer-alt-newsletter-title,
    .footer-alt-newsletter-copy {
      font-size: 30px;
      line-height: 1;
    }

    .footer-alt-tagline {
      font-size: 18px;
    }

    .footer-alt-label {
      font-size: 14px;
    }

    .footer-alt-link,
    .footer-alt-address {
      font-size: 20px;
    }

    .footer-alt-copyright,
    .footer-alt-legal-link {
      font-size: 16px;
    }
  }
</style>
