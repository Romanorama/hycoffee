</style>

<script is:inline>
  (function () {
    const switcher = document.getElementById('footer-version-switcher');
    if (!switcher) return;
    const options = Array.from(switcher.querySelectorAll('[data-footer-version]'));
    const STORAGE_KEY = 'hycoffee-footer-version';
    const versions = ['classic', 'alt'];

    function apply(version) {
      const next = versions.includes(version) ? version : 'classic';
      document.body.classList.toggle('footer-alt-active', next === 'alt');
      options.forEach((option) => {
        const active = option.dataset.footerVersion === next;
        option.classList.toggle('is-active', active);
        option.setAttribute('aria-pressed', String(active));
      });
    }

    apply(localStorage.getItem(STORAGE_KEY));

    options.forEach((option) => {
      option.addEventListener('click', () => {
        const next = option.dataset.footerVersion;
        if (!versions.includes(next)) return;
        localStorage.setItem(STORAGE_KEY, next);
        apply(next);
      });
    });
  })();
</script>
