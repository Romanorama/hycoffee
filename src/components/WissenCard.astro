---
import { Image } from 'astro:assets';
import type { WissenArticle } from '../lib/wissen';
import { DEFAULT_LANG, ui, type Lang } from '../lib/i18n';

interface Props {
  article: WissenArticle;
  imageSizes?: string;
  lang?: Lang;
}

const {
  article,
  imageSizes = '(min-width: 1600px) 33vw, (min-width: 1000px) 50vw, 100vw',
  lang = DEFAULT_LANG,
} = Astro.props;
const copy = ui[lang];
---

<article class="science-card">
  <span class="card-category">{article.categoryLabel}</span>
  <div class="card-image">
    {article.image && (
      <Image
        src={article.image}
        alt={article.title}
        widths={[400, 800, 1200]}
        sizes={imageSizes}
        format="webp"
        quality={72}
        loading="lazy"
        decoding="async"
      />
    )}
  </div>
  <h3 class="card-title">{article.title}</h3>
  <p class="card-subtitle">{article.subtitle}</p>
  <div class="card-footer">
    <div class="card-meta">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="10" stroke="#e3e2e0" stroke-width="1"></circle>
        <path d="M11 6v5l3 3" stroke="#e3e2e0" stroke-width="1" stroke-linecap="round"></path>
      </svg>
      <span>{article.readingTimeLabel}</span>
    </div>
    <a href={article.href} class="btn-tertiary">
      <span>{copy.knowledge.readArticle}</span>
      <svg class="arrow" width="14" height="11" viewBox="0 0 14 11" fill="none" aria-hidden="true">
        <path d="M1 5.5h12m0 0L8.5 1M13 5.5L8.5 10" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>
</article>

<style>
  .science-card {
    background: var(--warm-dark-grey);
    border-radius: var(--radius-card);
    padding: 40px 24px 20px;
    display: flex;
    flex-direction: column;
    min-height: 420px;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .card-category {
    font-family: var(--font-heading);
    font-size: var(--type-caption);
    line-height: 1.2;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    color: #f0efed;
    margin-bottom: 16px;
  }

  .card-image {
    border-radius: var(--radius-nested);
    height: clamp(190px, 20vw, 280px);
    margin-bottom: 24px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    -webkit-mask-image: linear-gradient(to bottom, #000 0 70%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 0 70%, transparent 100%);
    transition: transform 0.28s ease;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: var(--type-card-title-mobile);
    line-height: 1.15;
    font-weight: 400;
    color: #f0efed;
    margin-bottom: 8px;
  }

  .card-subtitle {
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy);
    line-height: 1.3;
    color: #f0efed;
    margin-bottom: auto;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 16px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #f0efed;
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy);
    white-space: nowrap;
  }

  .btn-tertiary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    padding: 12px 24px 8px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    line-height: 1;
    transition: filter 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  .btn-tertiary:hover,
  .btn-tertiary:focus-visible {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .arrow {
    width: 14px;
    height: 11px;
    transition: transform 0.2s ease;
  }

  @media (hover: hover) {
    .science-card:hover,
    .science-card:focus-within {
      transform: translateY(-4px);
      box-shadow: 0 12px 26px rgb(0 0 0 / 18%);
    }

    .science-card:hover .card-image img,
    .science-card:focus-within .card-image img {
      transform: scale(1.03);
    }

    .science-card:hover .arrow,
    .science-card:focus-within .arrow {
      transform: translateX(2px);
    }
  }

  @media (max-width: 768px) {
    .science-card {
      padding: 20px;
    }

    .card-category {
      font-size: var(--type-caption-sm);
      letter-spacing: 1.4px;
      margin-bottom: 10px;
    }

    .card-image {
      height: clamp(160px, 56vw, 240px);
      margin-bottom: 16px;
    }

    .card-title {
      margin-bottom: 4px;
    }

    .card-footer {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }

    .card-meta {
      font-size: var(--type-label);
      gap: 4px;
    }

    .card-meta svg {
      width: 16px;
      height: 16px;
    }

    .btn-tertiary {
      padding: 8px 16px;
      gap: 6px;
    }
  }
</style>
