---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  headline: string;
  image: ImageMetadata;
  ctaLabel: string;
  ctaUrl: string;
}

const { headline, image, ctaLabel, ctaUrl } = Astro.props;
---

<section class="hero">
  <div class="hero-image">
    <Picture
      src={image}
      alt="Klimaresilienter Kaffeeanbau"
      widths={[768, 1280, 1920]}
      sizes="(max-width: 768px) 100vw, 50vw"
      formats={['avif', 'webp']}
      quality={72}
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
  </div>
  <div class="hero-content">
    <h1 class="hero-heading">{headline}</h1>
    <a href={ctaUrl} class="btn btn-primary">{ctaLabel}</a>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
    height: calc(88svh - 88px);
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .hero-image {
    overflow: hidden;
    border-right: 1px solid var(--warm-dark-grey);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 56px 60px;
    text-align: center;
    gap: 48px;
    background: var(--white);
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: var(--type-display-xl);
    line-height: 0.88;
    letter-spacing: -1.15px;
    font-weight: 400;
    color: var(--warm-dark-grey);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 11px 28px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-lg);
    line-height: 1;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: 35svh 1fr;
      min-height: calc(88svh - 50px);
      height: auto;
    }

    .hero-image {
      border-right: none;
      border-bottom: 1px solid var(--warm-dark-grey);
    }

    .hero-content {
      padding: 44px 24px 16px;
      gap: 32px;
      justify-content: flex-start;
      padding-top: 8svh;
    }

    .hero-heading {
      font-size: var(--type-hero-mobile);
      line-height: 0.92;
      letter-spacing: -0.8px;
    }

    .btn-primary {
      padding: 13px 30px;
      font-size: var(--type-button-lg);
    }
  }
</style>
