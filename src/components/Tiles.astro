---
interface Tile {
  category: string;
  heading: string;
  body: string;
  ctaLabel: string;
  ctaUrl: string;
  color: 'violet' | 'green';
}

interface Props {
  tiles: Tile[];
}

const { tiles } = Astro.props;
---

<section class="tiles">
  {
    tiles.map((tile) => (
      <div class={`tile tile-${tile.color}`}>
        <span class="caption">{tile.category}</span>
        <h3>{tile.heading}</h3>
        <p class="tile-text">{tile.body}</p>
        <a href={tile.ctaUrl} class="btn btn-secondary">
          <span>{tile.ctaLabel}</span>
          <svg class="arrow" width="14" height="11" viewBox="0 0 14 11" fill="none">
            <path d="M1 5.5h12m0 0L8.5 1M13 5.5L8.5 10" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    ))
  }
</section>

<style>
  .tiles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .tile {
    padding: 40px 60px 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    min-height: 428px;
    border: none;
    overflow: hidden;
  }

  .tile + .tile {
    border-left: 1px solid var(--warm-dark-grey);
  }

  .tile-violet {
    background: var(--violet);
  }

  .tile-green {
    background: var(--green);
    color: #f5f5f5;
  }

  .caption {
    font-family: var(--font-heading);
    font-size: var(--type-caption);
    line-height: 1.2;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
  }

  .tile-violet .caption {
    color: var(--warm-dark-grey);
  }

  .tile-green .caption {
    color: var(--white);
  }

  h3 {
    font-family: var(--font-heading);
    font-size: var(--type-heading-sm);
    line-height: 0.92;
    font-weight: 400;
    margin-top: 8px;
    white-space: pre-line;
  }

  .tile-text {
    font-family: var(--font-heading);
    font-size: var(--type-copy-fluid);
    line-height: 1.3;
    max-width: 547px;
    margin-top: 4px;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 10px 24px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button);
    margin-top: 16px;
    transition: opacity 0.2s;
  }

  .btn-secondary:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .arrow {
    width: 14px;
    height: 11px;
    transform: rotate(0deg) translateX(0) !important;
    transition: transform 0.3s ease;
  }

  .btn-secondary:hover .arrow {
    transform: rotate(0deg) translateX(4px) !important;
  }

  @media (max-width: 768px) {
    .tiles {
      grid-template-columns: 1fr;
    }

    .tile {
      padding: 32px 24px 40px;
      min-height: 320px;
    }

    .tile + .tile {
      border-top: 1px solid var(--warm-dark-grey);
      border-left: none;
    }
  }
</style>
