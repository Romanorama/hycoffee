---
import WissenCard from './WissenCard.astro';
import { getRandomWissenArticles } from '../lib/wissenArticles';

const featuredArticles = getRandomWissenArticles(3);
---

<section class="science">
  <div class="science-header">
    <span class="caption">WISSEN</span>
    <h2 class="science-heading">
      Zwischen Forschung <span class="science-heading-nowrap">und Markt</span>
    </h2>
    <p class="science-text">
      Wir verbinden wissenschaftliche Erkenntnisse mit der Praxis des
      Kaffeeanbaus. In unseren Artikeln teilen wir neue Erkenntnisse und
      Perspektiven aus unserer Arbeit.
    </p>
    <a href="/wissen" class="science-link">
      <span>Zu den Artikeln</span>
      <span class="science-link-arrow" aria-hidden="true">›</span>
    </a>
  </div>
  <div class="science-cards">
    {
      featuredArticles.map((article) => (
        <WissenCard
          article={article}
          imageSizes="(min-width: 1201px) 30vw, (min-width: 769px) 50vw, 100vw"
        />
      ))
    }
  </div>
</section>

<style>
  .science {
    padding: 80px 60px;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .science-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .caption {
    font-family: var(--font-heading);
    font-size: var(--type-caption);
    line-height: 1.2;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    display: block;
    margin-bottom: 24px;
  }

  .science-heading {
    font-family: var(--font-heading);
    font-size: var(--type-heading-lg);
    line-height: 1.02;
    letter-spacing: -3px;
    font-weight: 400;
    color: var(--grey-10);
    margin-bottom: 32px;
    max-width: 682px;
    margin-left: auto;
    margin-right: auto;
  }

  .science-heading-nowrap {
    white-space: nowrap;
  }

  .science-text {
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy-lg);
    line-height: 1.1;
    color: var(--warm-dark-grey);
    max-width: 1000px;
    margin: 0 auto 24px;
  }

  .science-link {
    font-family: var(--font-ui);
    font-size: var(--type-button-lg);
    color: var(--violet);
    display: inline-flex;
    align-items: center;
    gap: 0.22em;
    line-height: 1;
    transition: opacity 0.26s ease;
  }

  .science-link-arrow {
    display: inline-block;
    transition: transform 0.26s ease;
  }

  .science-link:hover,
  .science-link:focus-visible {
    opacity: 0.86;
  }

  .science-link:hover .science-link-arrow,
  .science-link:focus-visible .science-link-arrow {
    transform: translateX(3px);
  }

  .science-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px;
  }

  @media (max-width: 1200px) {
    .science-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .science {
      padding: 48px 24px;
    }

    .science-heading {
      letter-spacing: -0.5px;
    }

    .science-header {
      margin-bottom: 32px;
    }

    .science-cards {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
