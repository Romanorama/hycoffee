<style>
  .science {
    padding: 80px 60px;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .science-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .caption {
    font-family: var(--font-heading);
    font-size: var(--type-caption);
    line-height: 1.2;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    display: block;
    margin-bottom: 24px;
  }

  .science-heading {
    font-family: var(--font-heading);
    font-size: var(--type-heading-lg);
    line-height: 1.02;
    letter-spacing: -3px;
    font-weight: 400;
    color: var(--grey-10);
    margin-bottom: 32px;
    max-width: 682px;
    margin-left: auto;
    margin-right: auto;
  }

  .science-heading-nowrap {
    white-space: nowrap;
  }

  .science-text {
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy-lg);
    line-height: 1.1;
    color: var(--warm-dark-grey);
    max-width: 1000px;
    margin: 0 auto 24px;
  }

  .science-link {
    font-family: var(--font-ui);
    font-size: var(--type-button-lg);
    color: var(--violet);
    display: inline-flex;
    align-items: center;
    gap: 0.22em;
    line-height: 1;
    transition: opacity 0.26s ease;
  }

  .science-link-arrow {
    display: inline-block;
    transition: transform 0.26s ease;
  }

  .science-link:hover,
  .science-link:focus-visible {
    opacity: 0.86;
  }

  .science-link:hover .science-link-arrow,
  .science-link:focus-visible .science-link-arrow {
    transform: translateX(3px);
  }

  .science-cards {
    display: grid;
    grid-template-columns: 1fr 1px 1fr 1px 1fr;
    gap: 0 20px;
  }

  .science-cards::before,
  .science-cards::after {
    content: '';
    background: var(--warm-dark-grey);
    grid-row: 1;
    align-self: stretch;
  }

  .science-cards::before {
    grid-column: 2;
  }

  .science-cards::after {
    grid-column: 4;
  }

  .science-card {
    background: var(--warm-dark-grey);
    border-radius: var(--radius-card);
    padding: 32px;
    display: flex;
    flex-direction: column;
    min-height: 655px;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .science-card .caption {
    color: var(--light-grey);
    margin-bottom: 16px;
  }

  .card-image {
    background: #d9d9d9;
    border-radius: var(--radius-nested);
    flex: 1;
    min-height: 260px;
    margin-bottom: 24px;
    transition: transform 0.28s ease;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: var(--type-card-title);
    line-height: 1.14;
    font-weight: 400;
    color: var(--light-grey);
    margin-bottom: 8px;
  }

  .card-subtitle {
    font-family: var(--font-heading);
    font-size: var(--type-copy-fluid);
    line-height: 1.3;
    color: var(--light-grey);
    margin-bottom: 24px;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .btn-tertiary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    padding: 10px 24px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button);
    transition: opacity 0.2s;
  }

  .btn-tertiary:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .arrow {
    width: 14px;
    height: 11px;
    transition: transform 0.2s ease;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--light-grey);
    font-family: var(--font-heading);
    font-size: var(--type-copy-fluid);
  }

  @media (hover: hover) {
    .science-card:hover,
    .science-card:focus-within {
      transform: translateY(-4px);
      box-shadow: 0 12px 26px rgb(0 0 0 / 18%);
    }

    .science-card:hover .card-image,
    .science-card:focus-within .card-image {
      transform: scale(1.02);
    }

    .science-card:hover .arrow,
    .science-card:focus-within .arrow {
      transform: translateX(2px);
    }
  }

  @media (max-width: 1600px) {
    .science-cards {
      grid-template-columns: 1fr 1px 1fr;
    }

    .science-cards::after {
      display: none;
    }

    .science-card:nth-child(3) {
      display: none;
    }
  }

  @media (max-width: 1000px) {
    .science-cards {
      grid-template-columns: 1fr 1px 1fr;
    }

    .science-cards::before {
      display: block;
    }

    .science-cards::after {
      display: none;
    }

    .science-card:nth-child(3) {
      display: none;
    }

    .science-card:nth-child(2) {
      display: flex;
    }
  }

  @media (max-width: 768px) {
    .science {
      padding: 48px 24px;
    }

    .science-heading {
      letter-spacing: -0.5px;
    }

    .science-header {
      margin-bottom: 32px;
    }

    .science-cards {
      grid-template-columns: 1fr;
      gap: 16px 0;
    }

    .science-cards::before,
    .science-cards::after {
      display: none;
    }

    .science-card:nth-child(2) {
      display: flex;
    }

    .science-card:nth-child(3) {
      display: none;
    }

    .science-card {
      min-height: auto;
      padding: 20px;
      border-radius: var(--radius-card);
    }

    .science-card .caption {
      font-size: var(--type-caption-sm);
      letter-spacing: 1.4px;
      margin-bottom: 10px;
    }

    .card-image {
      min-height: 160px;
      margin-bottom: 16px;
    }

    .card-title {
      font-size: var(--type-card-title-mobile);
      margin-bottom: 4px;
    }

    .card-subtitle {
      font-size: var(--type-hal-copy);
      margin-bottom: 16px;
    }

    .card-footer {
      gap: 12px;
    }

    .btn-tertiary {
      padding: 8px 16px;
      font-size: var(--type-button-sm);
      gap: 6px;
    }

    .card-meta {
      font-size: var(--type-label);
      gap: 4px;
    }

    .card-meta svg {
      width: 16px;
      height: 16px;
    }
  }
</style>
