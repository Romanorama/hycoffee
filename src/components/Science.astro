<style>
  .science {
    padding: 80px 60px;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .science-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .caption {
    font-family: var(--font-heading);
    font-size: 20.9px;
    line-height: 16.32px;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    display: block;
    margin-bottom: 24px;
  }

  .science-heading {
    font-family: var(--font-heading);
    font-size: 76.6px;
    line-height: 78px;
    letter-spacing: -3px;
    font-weight: 400;
    color: var(--grey-10);
    margin-bottom: 32px;
    max-width: 682px;
    margin-left: auto;
    margin-right: auto;
  }

  .science-text {
    font-family: var(--font-heading);
    font-size: 36px;
    line-height: 36px;
    color: var(--warm-dark-grey);
    max-width: 1000px;
    margin: 0 auto 24px;
  }

  .science-link {
    font-family: var(--font-ui);
    font-size: 27px;
    color: var(--violet);
    display: inline-block;
  }

  .science-link:hover {
    opacity: 0.7;
  }

  .science-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .science-card {
    background: var(--warm-dark-grey);
    border-radius: 10px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    min-height: 655px;
    border-right: 1px solid #3a3a3a;
  }

  .science-card:last-child {
    border-right: none;
  }

  .science-card .caption {
    color: var(--light-grey);
    margin-bottom: 16px;
  }

  .card-image {
    background: #d9d9d9;
    border-radius: 4px;
    flex: 1;
    min-height: 260px;
    margin-bottom: 24px;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 40px;
    line-height: 45.76px;
    font-weight: 400;
    color: var(--light-grey);
    margin-bottom: 8px;
  }

  .card-subtitle {
    font-family: var(--font-heading);
    font-size: 23px;
    line-height: 26px;
    color: var(--light-grey);
    margin-bottom: 24px;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .btn-tertiary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    padding: 10px 24px;
    border-radius: 3px;
    font-family: var(--font-ui);
    font-size: 20px;
    transition: opacity 0.2s;
  }

  .btn-tertiary:hover {
    opacity: 0.85;
  }

  .arrow {
    width: 14px;
    height: 11px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--light-grey);
    font-family: var(--font-heading);
    font-size: 23px;
  }
</style>
