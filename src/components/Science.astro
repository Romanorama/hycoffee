        </a>
        <div class="card-meta">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <circle cx="11" cy="11" r="10" stroke="#e3e2e0" stroke-width="1"/>
            <path d="M11 6v5l3 3" stroke="#e3e2e0" stroke-width="1" stroke-linecap="round"/>
          </svg>
          <span>6 Min</span>
        </div>
      </div>
    </article>
