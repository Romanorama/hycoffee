---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { DEFAULT_LANG, type Lang } from '../lib/i18n';

interface Props {
  slug: string;
  name: string;
  species: 'arabica' | 'excelsa';
  country: string;
  score: string;
  process: string;
  variety: string;
  harvest: string;
  region: string;
  altitude: string;
  flavourNotes: string;
  intro: string;
  resilienceText: string;
  socialText: string;
  heroImage: ImageMetadata | null;
  heroAlt?: string;
  pdfDownloadHref?: string | null;
  samplesSoldOut: boolean;
  lang?: Lang;
  addSampleLabel?: string;
  soldOutLabel?: string;
  soldOutAriaLabel?: string;
  productSheetLabel?: string;
}

const {
  slug,
  name,
  species,
  country,
  score,
  process,
  variety,
  harvest,
  region,
  altitude,
  flavourNotes,
  intro,
  resilienceText,
  socialText,
  heroImage,
  heroAlt,
  pdfDownloadHref,
  samplesSoldOut,
  lang = DEFAULT_LANG,
  addSampleLabel,
  soldOutLabel,
  soldOutAriaLabel,
  productSheetLabel,
} = Astro.props;

const speciesLabel = species === 'excelsa' ? 'Excelsa' : 'Arabica';
const labels = {
  de: {
    variety: 'Varietät',
    harvest: 'Ernte',
    origin: 'Herkunft',
    altitude: 'Höhe',
    resilience: 'Klimaresilient',
    social: 'Sozial verantwortlich',
    addSample: 'Sample hinzufügen',
    soldOut: 'Ausverkauft',
    soldOutLabel: 'Samples ausverkauft',
    productSheet: 'Product Sheet',
  },
  en: {
    variety: 'Variety',
    harvest: 'Harvest',
    origin: 'Origin',
    altitude: 'Altitude',
    resilience: 'Climate resilient',
    social: 'Socially responsible',
    addSample: 'Add Sample',
    soldOut: 'Sold out',
    soldOutLabel: 'Samples sold out',
    productSheet: 'Product Sheet',
  },
}[lang];
const rowLabels = {
  ...labels,
  addSample: addSampleLabel || labels.addSample,
  soldOut: soldOutLabel || labels.soldOut,
  soldOutLabel: soldOutAriaLabel || soldOutLabel || labels.soldOutLabel,
  productSheet: productSheetLabel || labels.productSheet,
};
const sampleButtonClass = `btn-sample${samplesSoldOut ? ' is-sold-out' : ''}`;
const sampleButtonText = samplesSoldOut ? rowLabels.soldOut : rowLabels.addSample;
const sampleButtonIcon = samplesSoldOut ? '!' : '+';
const sampleButtonLabel = samplesSoldOut ? rowLabels.soldOutLabel : rowLabels.addSample;
const pdfDownloadFilename = `${name.replace(/[\\/:*?"<>|]+/g, '').trim() || 'Product Sheet'}.pdf`;
---

<details class="table-row-wrapper">
  <summary class="table-row">
    <span class="col col-name cell">
      <span class="availability-dot"></span>
      <span class="row-arrow">›</span> {name}
    </span>
    <span class="col col-species cell">{speciesLabel}</span>
    <span class="col col-country cell">{country}</span>
    <span class="col col-score cell">{score}</span>
    <span class="col col-process cell">{process}</span>
    <span class="col col-action cell">
      {pdfDownloadHref && (
        <a class="btn-download-row" href={pdfDownloadHref} download={pdfDownloadFilename} onclick="event.stopPropagation()">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 1v10m0 0L4 7.5M8 11l4-3.5M1 14h14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{rowLabels.productSheet}</span>
        </a>
      )}
      <button type="button" class={sampleButtonClass} data-sample-action data-sample-slug={slug} data-sample-name={name} data-sample-sold-out={samplesSoldOut ? 'true' : 'false'} aria-label={sampleButtonLabel} onclick="event.stopPropagation()">
        <span class="sample-plus">{sampleButtonIcon}</span>
        <span class="sample-text">{sampleButtonText}</span>
      </button>
    </span>
  </summary>
  <div class="row-details">
    <p class="detail-intro">{intro}</p>
    <div class="row-specs">
      <div class="spec"><span class="spec-label">{labels.variety}</span><span class="spec-value">{variety}</span></div>
      <div class="spec"><span class="spec-label">{labels.harvest}</span><span class="spec-value">{harvest}</span></div>
      <div class="spec"><span class="spec-label">{labels.origin}</span><span class="spec-value">{region}</span></div>
      <div class="spec"><span class="spec-label">{labels.altitude}</span><span class="spec-value">{altitude}</span></div>
      <div class="spec"><span class="spec-label">Flavour Notes</span><span class="spec-value">{flavourNotes}</span></div>
    </div>
    <div class="row-details-inner">
      <div class="detail-col">
        <h4 class="detail-label">{labels.resilience}</h4>
        <p class="detail-text">{resilienceText}</p>
      </div>
      <div class="detail-col">
        <h4 class="detail-label">{labels.social}</h4>
        <p class="detail-text">{socialText}</p>
      </div>
      {heroImage && (
        <figure class="row-hero">
          <Image src={heroImage} alt={heroAlt ?? name} widths={[600, 900, 1200]} sizes="(max-width: 768px) 100vw, 40vw" format="webp" quality={72} loading="lazy" decoding="async" />
        </figure>
      )}
    </div>
    <div class="row-details-actions">
      {pdfDownloadHref && (
        <a class="btn-download-row" href={pdfDownloadHref} download={pdfDownloadFilename}>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 1v10m0 0L4 7.5M8 11l4-3.5M1 14h14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{rowLabels.productSheet}</span>
        </a>
      )}
      <button type="button" class={sampleButtonClass} data-sample-action data-sample-slug={slug} data-sample-name={name} data-sample-sold-out={samplesSoldOut ? 'true' : 'false'} aria-label={sampleButtonLabel}>
        <span class="sample-plus">{sampleButtonIcon}</span>
        <span class="sample-text">{sampleButtonText}</span>
      </button>
    </div>
  </div>
</details>

<style>
  .table-row-wrapper {
    border-top: 1px solid var(--warm-dark-grey);
    overflow-anchor: none;
  }

  .table-row {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 0.8fr 1fr 300px;
    min-height: 82px;
    padding: 0 60px;
    background: var(--white);
    align-items: center;
    justify-items: start;
    cursor: pointer;
    list-style: none;
  }

  .table-row::-webkit-details-marker {
    display: none;
  }

  .table-row::marker {
    content: '';
  }

  .table-row:hover,
  .table-row-wrapper[open] .table-row {
    background: var(--warm-grey-light);
  }

  .table-row-wrapper[open] .row-arrow {
    transform: rotate(90deg);
  }

  .cell {
    font-family: var(--font-heading);
    font-size: var(--type-copy-fluid);
    line-height: 1.2;
    color: var(--warm-dark-grey);
    text-align: left;
  }

  .col-name {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .col-action {
    display: flex;
    align-items: stretch;
    gap: 8px;
  }

  .table-row .col-action {
    justify-self: end;
  }

  .availability-dot {
    width: 12px;
    height: 12px;
    border-radius: var(--radius-round);
    background: #8edf8e;
    flex-shrink: 0;
    margin-right: 4px;
    box-shadow: 0 0 8px 3px rgba(142, 223, 142, 0.5);
    position: relative;
    top: 2px;
    left: -4px;
    transition: all 0.4s ease;
  }

  .table-row-wrapper[open] .availability-dot {
    width: 7px;
    height: 7px;
    left: -12px;
    box-shadow: 0 0 5px 2px rgba(142, 223, 142, 0.4);
  }

  .row-arrow {
    font-size: var(--type-copy-fluid);
    margin-right: 4px;
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .row-details {
    background: var(--warm-grey-light);
    border-top: 1px solid var(--light-grey);
    padding: 28px 60px 0;
  }

  .detail-intro {
    font-family: var(--font-heading);
    font-size: var(--type-copy-detail);
    line-height: 1.5;
    color: var(--warm-dark-grey);
    padding: 0;
    max-width: calc(50% - 24px);
  }

  .row-specs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px;
    border-bottom: 1px solid rgba(36, 33, 25, 0.12);
    margin: 32px 0 0;
    padding: 0 0 20px;
  }

  .spec {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .spec-label {
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(36, 33, 25, 0.55);
  }

  .spec-value {
    font-family: var(--font-heading);
    font-size: var(--type-copy-detail);
    line-height: 1.3;
    color: var(--warm-dark-grey);
  }

  .row-details-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
    padding: 24px 0 32px;
    align-items: start;
  }

  .detail-label {
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--warm-dark-grey);
    margin-bottom: 8px;
    font-weight: 400;
  }

  .detail-text {
    font-family: var(--font-heading);
    font-size: var(--type-copy-detail);
    line-height: 1.4;
    color: var(--warm-dark-grey);
  }

  .row-hero {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-media);
    aspect-ratio: 4 / 3;
    background: var(--light-grey);
  }

  .row-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .btn-sample {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    padding: 8px 16px;
    border: 1px solid var(--warm-dark-grey);
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    letter-spacing: 0.42px;
    cursor: pointer;
    transition: filter 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
  }

  .btn-sample.is-sold-out {
    background: var(--yellow);
    color: var(--warm-dark-grey);
  }

  .btn-sample.is-active {
    background: var(--warm-dark-grey);
    color: var(--white);
  }

  .btn-sample:hover,
  .btn-download-row:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .btn-download-row:hover {
    text-shadow: var(--button-text-hover-glow);
  }

  .sample-plus {
    font-size: var(--type-copy-fluid);
    letter-spacing: 0.6px;
  }

  .btn-sample.is-sold-out .sample-plus {
    width: 15px;
    height: 15px;
    border: 1px solid currentColor;
    border-radius: var(--radius-round);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-size: 10px;
    line-height: 1;
  }

  .btn-sample span:not(.sample-plus),
  .btn-download-row span {
    transform: translateY(1px);
  }

  .btn-download-row {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--black);
    color: var(--white);
    padding: 8px 16px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    letter-spacing: 0.42px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .row-details-actions {
    display: none;
  }

  .table-row-wrapper.is-animating {
    overflow: hidden;
    will-change: height;
  }

  .table-row-wrapper.is-animating .row-details {
    pointer-events: none;
    will-change: opacity, transform;
  }

  @media (max-width: 768px) {
    .col-country,
    .col-process,
    .col-action {
      display: none;
    }

    .table-row {
      grid-template-columns: 1.8fr 1fr 0.8fr;
      padding: 20px 24px;
    }

    .row-details {
      padding: 20px 24px 0;
      display: flex;
      flex-direction: column;
    }

    .detail-intro {
      max-width: 100%;
      padding: 0;
      order: 1;
    }

    .row-details-inner .row-hero {
      order: -1;
      max-width: 260px;
      margin: 0 0 8px;
    }

    .row-specs {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 20px 0 0;
      padding: 0 0 16px;
      order: 3;
    }

    .row-details-inner {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 20px 0 16px;
      order: 4;
    }

    .row-details-actions {
      display: flex;
      gap: 8px;
      padding: 16px 0 8px;
      order: 2;
    }

    .availability-dot,
    .table-row-wrapper[open] .availability-dot {
      left: -10px;
      width: 12px;
      height: 12px;
      box-shadow: 0 0 8px 3px rgba(142, 223, 142, 0.5);
    }
  }
</style>
