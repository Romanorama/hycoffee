---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  slug: string;
  name: string;
  species: 'arabica' | 'excelsa';
  country: string;
  score: string;
  process: string;
  variety: string;
  harvest: string;
  region: string;
  altitude: string;
  flavourNotes: string;
  intro: string;
  resilienceText: string;
  socialText: string;
  heroImage: ImageMetadata | null;
  heroAlt?: string;
  pdfDownloadHref?: string | null;
  samplesSoldOut: boolean;
}

const {
  slug,
  name,
  species,
  country,
  score,
  process,
  variety,
  harvest,
  region,
  altitude,
  flavourNotes,
  intro,
  resilienceText,
  socialText,
  heroImage,
  heroAlt,
  pdfDownloadHref,
  samplesSoldOut,
} = Astro.props;

const speciesLabel = species === 'excelsa' ? 'Excelsa' : 'Arabica';
const sampleButtonClass = `btn-sample${samplesSoldOut ? ' is-sold-out' : ''}`;
const sampleButtonText = samplesSoldOut ? 'Sold out' : 'Add Sample';
const sampleButtonIcon = samplesSoldOut ? '!' : '+';
const sampleButtonLabel = samplesSoldOut ? 'Samples sold out' : 'Add Sample';
---

<details class="table-row-wrapper">
  <summary class="table-row">
    <span class="col col-name cell">
      <span class="availability-dot"></span>
      <span class="row-arrow">›</span> {name}
    </span>
    <span class="col col-species cell">{speciesLabel}</span>
    <span class="col col-country cell">{country}</span>
    <span class="col col-score cell">{score}</span>
    <span class="col col-process cell">{process}</span>
    <span class="col col-action cell">
      {pdfDownloadHref && (
        <a class="btn-download-row" href={pdfDownloadHref} download onclick="event.stopPropagation()">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 1v10m0 0L4 7.5M8 11l4-3.5M1 14h14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Product Sheet</span>
        </a>
      )}
      <button type="button" class={sampleButtonClass} data-sample-action data-sample-slug={slug} data-sample-name={name} data-sample-sold-out={samplesSoldOut ? 'true' : 'false'} aria-label={sampleButtonLabel} onclick="event.stopPropagation()">
        <span class="sample-plus">{sampleButtonIcon}</span>
        <span class="sample-text">{sampleButtonText}</span>
      </button>
    </span>
  </summary>
  <div class="row-details">
    <p class="detail-intro">{intro}</p>
    <div class="row-specs">
      <div class="spec"><span class="spec-label">Varietät</span><span class="spec-value">{variety}</span></div>
      <div class="spec"><span class="spec-label">Ernte</span><span class="spec-value">{harvest}</span></div>
      <div class="spec"><span class="spec-label">Herkunft</span><span class="spec-value">{region}</span></div>
      <div class="spec"><span class="spec-label">Höhe</span><span class="spec-value">{altitude}</span></div>
      <div class="spec"><span class="spec-label">Flavour Notes</span><span class="spec-value">{flavourNotes}</span></div>
    </div>
    <div class="row-details-inner">
      <div class="detail-col">
        <h4 class="detail-label">Klimaresilient</h4>
        <p class="detail-text">{resilienceText}</p>
      </div>
      <div class="detail-col">
        <h4 class="detail-label">Sozial verantwortlich</h4>
        <p class="detail-text">{socialText}</p>
      </div>
      {heroImage && (
        <figure class="row-hero">
          <Image src={heroImage} alt={heroAlt ?? name} widths={[600, 900, 1200]} sizes="(max-width: 768px) 100vw, 40vw" format="webp" quality={72} loading="lazy" decoding="async" />
        </figure>
      )}
    </div>
    <div class="row-details-actions">
      {pdfDownloadHref && (
        <a class="btn-download-row" href={pdfDownloadHref} download>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 1v10m0 0L4 7.5M8 11l4-3.5M1 14h14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Product Sheet</span>
        </a>
      )}
      <button type="button" class={sampleButtonClass} data-sample-action data-sample-slug={slug} data-sample-name={name} data-sample-sold-out={samplesSoldOut ? 'true' : 'false'} aria-label={sampleButtonLabel}>
        <span class="sample-plus">{sampleButtonIcon}</span>
        <span class="sample-text">{sampleButtonText}</span>
      </button>
    </div>
  </div>
</details>
