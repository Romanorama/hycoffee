---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  blurb: string;
  missionHeading: string;
  ctaLabel: string;
}

const { images, blurb, missionHeading, ctaLabel } = Astro.props;
const doubled = [...images, ...images];
---

<section class="team">
  <div class="team-photos">
    <div class="team-photos-track">
      {doubled.map((photo) => (
        <div class="team-photo-frame">
          <Image src={photo} alt="Team" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
  <div class="team-content">
    <div class="team-text">
      <p class="team-description">{blurb}</p>
    </div>
    <div class="team-right">
      <h2 class="team-heading">{missionHeading}</h2>
      <a href="/ueber-uns" class="btn btn-secondary">
        <span>{ctaLabel}</span>
        <svg class="arrow" width="14" height="11" viewBox="0 0 14 11" fill="none">
          <path d="M1 5.5h12m0 0L8.5 1M13 5.5L8.5 10" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .team {
    background: var(--warm-grey-light);
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .team-photos {
    width: 100%;
    height: 181px;
    overflow: hidden;
    filter: grayscale(100%);
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .team-photos-track {
    display: flex;
    height: 100%;
    gap: 0;
    animation: strip-scroll 40s linear infinite;
    will-change: transform;
  }

  @keyframes strip-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .team-photo-frame {
    position: relative;
    display: flex;
    align-items: stretch;
    height: 100%;
    flex-shrink: 0;
    margin-right: -2px;
    overflow: visible;
    z-index: 1;
    border-left: 1px solid var(--warm-dark-grey);
    border-right: 1px solid var(--warm-dark-grey);
    box-sizing: border-box;
    transform: translateZ(0) scale(1);
    transform-origin: center center;
    transition: transform 460ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
    backface-visibility: hidden;
  }

  .team-photo-frame img {
    height: 100%;
    width: auto;
    min-width: 180px;
    object-fit: cover;
    display: block;
  }

  .team-photo-frame:hover {
    z-index: 10;
    transform: translateZ(0) scale(1.12);
  }

  .team-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 80px 60px;
    gap: 60px;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .team-text {
    display: flex;
    align-items: flex-start;
  }

  .team-description {
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy-lg);
    line-height: 1.1;
    color: var(--warm-dark-grey);
  }

  .team-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
  }

  .team-heading {
    font-family: var(--font-heading);
    font-size: var(--type-heading);
    line-height: 0.94;
    letter-spacing: -1.5px;
    font-weight: 400;
    color: var(--warm-dark-grey);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 10px 24px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button);
    transition: opacity 0.2s;
  }

  .btn-secondary:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .arrow {
    width: 14px;
    height: 11px;
  }

  @media (max-width: 768px) {
    .team-content {
      grid-template-columns: 1fr;
      padding: 40px 24px;
      gap: 32px;
    }

    .team-photos {
      height: 140px;
    }
  }
</style>
