---
import { Image } from 'astro:assets';

import speciesPhoto01 from '../../Images/IMG_9052.jpeg';
---

<section class="species-train" data-species-train aria-labelledby="species-train-heading">
  <details class="species-train-panel">
    <summary class="species-locomotive">
      <h2 id="species-train-heading" class="species-locomotive-heading">
        Es gibt 130 bekannte Kaffeearten, viele davon werden nicht kommerziell genutzt. Noch nicht.
        <span class="species-locomotive-arrow" aria-hidden="true">›</span>
      </h2>
    </summary>

    <div class="species-coupling">
      <div class="species-wagons-shell">
        <div class="species-wagons-motion">
          <article class="species-wagon">
            <div class="species-wagon-layout">
              <div class="species-main-wrap">
                <div class="species-wagon-photo">
                  <Image
                    src={speciesPhoto01}
                    alt="Young coffee plants in nursery beds"
                    class="species-wagon-image"
                  />
                </div>
                <p class="species-wagon-text">
                  Von über 130 bekannten Coffea-Arten werden heute nur wenige kommerziell genutzt.
                </p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </details>
</section>

<script>
  const initSpeciesTrain = () => {
    const section = document.querySelector('[data-species-train]');
    if (!section || section.dataset.trainReady === 'true') return;
    section.dataset.trainReady = 'true';

    const panel = section.querySelector('.species-train-panel');
    if (!panel) return;

    const syncOpenState = () => {
      section.classList.toggle('is-open', panel.open);
    };

    panel.addEventListener('toggle', syncOpenState);
    syncOpenState();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSpeciesTrain, { once: true });
  } else {
    initSpeciesTrain();
  }
</script>

<style>
  .species-train {
    background: var(--white);
    color: var(--warm-dark-grey);
    overflow-x: clip;
    --species-train-shift: 0;
    --species-loco-duration: 2.5s;
    --species-reveal-duration: 2.5s;
  }

  .species-train.is-open {
    --species-train-shift: -42%;
  }

  .species-train-panel {
    width: 100%;
    position: relative;
    padding-bottom: 0;
    transition: padding-bottom var(--species-reveal-duration) cubic-bezier(0.22, 1, 0.36, 1);
    will-change: padding-bottom;
  }

  .species-locomotive {
    list-style: none;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 84px 60px 56px;
    cursor: pointer;
    background: var(--white);
    transform: translateX(var(--species-train-shift));
    transition: transform var(--species-loco-duration) cubic-bezier(0.22, 1, 0.36, 1);
  }

  .species-locomotive::-webkit-details-marker {
    display: none;
  }

  .species-coupling {
    transform: translateX(var(--species-train-shift));
    transition: transform var(--species-loco-duration) cubic-bezier(0.22, 1, 0.36, 1);
  }

  .species-locomotive-heading {
    font-family: var(--font-heading);
    font-size: var(--type-display);
    line-height: 0.98;
    letter-spacing: -1.35px;
    font-weight: 400;
    color: var(--warm-dark-grey);
    display: flex;
    align-items: baseline;
    gap: 0.35em;
  }

  .species-locomotive-arrow {
    display: inline-block;
    transition: transform 0.45s ease;
  }

  .species-train-panel[open] .species-locomotive-arrow {
    transform: rotate(90deg);
  }

  .species-wagons-shell {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition:
      max-height var(--species-reveal-duration) ease,
      opacity calc(var(--species-reveal-duration) * 0.8) ease;
  }

  .species-train-panel[open] > .species-coupling > .species-wagons-shell {
    max-height: 2200px;
    opacity: 1;
  }

  .species-wagons-motion {
    width: 100%;
  }

  .species-wagon {
    padding: 24px 60px 56px;
  }

  .species-wagon-layout {
    max-width: var(--container-max);
    margin: 0 auto;
    min-height: 1px;
    position: relative;
  }

  .species-main-wrap {
    display: grid;
    grid-template-columns: minmax(280px, 460px) minmax(140px, 210px);
    gap: 10px;
    align-items: start;
  }

  .species-wagon-photo {
    width: 100%;
    aspect-ratio: 1 / 1.02;
    overflow: hidden;
    max-width: 460px;
  }

  .species-wagon-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .species-wagon-text {
    font-family: var(--font-heading);
    font-size: var(--type-label);
    line-height: 1.34;
    color: rgba(36, 33, 25, 0.84);
    max-width: 20ch;
    margin-top: 4px;
  }

  @media (min-width: 760px) {
    .species-train-panel[open] {
      padding-bottom: clamp(420px, 62vh, 680px);
    }

    .species-wagons-shell {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      overflow: visible;
      max-height: none;
      opacity: 0;
      transition: opacity calc(var(--species-reveal-duration) * 0.8) ease;
      pointer-events: none;
    }

    .species-train-panel[open] > .species-coupling > .species-wagons-shell {
      opacity: 1;
    }

    .species-wagon {
      padding: 0;
    }

    .species-wagon-layout {
      max-width: none;
      margin: 0;
      min-height: clamp(420px, 62vh, 680px);
    }

    .species-main-wrap {
      position: absolute;
      right: -700px;
      top: -170px;
    }
  }

  @media (max-width: 759px) {
    .species-locomotive {
      padding: 48px 24px 40px;
      transform: none;
      transition: none;
    }

    .species-coupling {
      transform: none;
      transition: none;
    }

    .species-locomotive-heading {
      font-size: var(--type-species-mobile);
      line-height: 1;
      flex-wrap: wrap;
    }

    .species-wagon {
      padding: 20px 24px 44px;
    }

    .species-wagon-layout {
      min-height: 1px;
    }

    .species-main-wrap {
      grid-template-columns: 1fr;
      gap: 10px;
      position: static;
    }

    .species-wagon-text {
      max-width: 28ch;
      margin-top: 6px;
    }
  }
</style>
