---
interface Props {
  heading: string;
  body: string;
}

const { heading, body } = Astro.props;
---

<section class="values">
  <div class="values-inner">
    <h2 class="values-heading">{heading}</h2>
    <p class="values-text">{body}</p>
  </div>
</section>

<style>
  .values {
    background: var(--yellow);
    border-bottom: 1px solid var(--warm-dark-grey);
    padding: 80px 60px;
    min-height: 496px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .values-inner {
    text-align: center;
    max-width: 1343px;
  }

  .values-heading {
    font-family: var(--font-heading);
    font-size: var(--type-heading-lg);
    line-height: 1.02;
    letter-spacing: -3px;
    font-weight: 400;
    color: var(--warm-dark-grey);
    margin-bottom: 32px;
    white-space: pre-line;
  }

  .values-text {
    font-family: var(--font-heading);
    font-size: var(--type-copy-xl);
    line-height: 1.13;
    color: var(--warm-dark-grey);
    max-width: 1200px;
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .values {
      padding: 48px 24px;
      min-height: auto;
    }
  }
</style>
