<style>
  .press {
    padding: 80px 60px;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .press-heading {
    font-family: var(--font-heading);
    font-size: 75px;
    line-height: 70.3px;
    letter-spacing: -1.5px;
    font-weight: 400;
    text-align: center;
    margin-bottom: 60px;
  }

  .press-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .press-card {
    border-right: 1px solid var(--warm-dark-grey);
    min-height: 587px;
  }

  .press-card:last-child {
    border-right: none;
  }

  .press-card-inner {
    padding: 12px 24px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .caption {
    font-family: var(--font-heading);
    font-size: 20.9px;
    line-height: 16.32px;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--warm-dark-grey);
  }

  .press-divider {
    width: 100%;
    height: 1px;
    background: var(--warm-dark-grey);
    margin: 12px 0;
  }

  .press-title {
    font-family: var(--font-ui);
    font-size: 35px;
    line-height: 40.8px;
    font-weight: 400;
    letter-spacing: 0.7px;
    color: var(--warm-dark-grey);
    margin-bottom: 16px;
  }

  .press-image {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .press-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .press-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .press-logo {
    height: 24px;
    width: auto;
  }

  .press-time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-heading);
    font-size: 23px;
    color: var(--warm-dark-grey);
  }

  .press-excerpt {
    font-family: var(--font-heading);
    font-size: 16px;
    line-height: 17px;
    color: var(--warm-dark-grey);
    margin-bottom: 16px;
    flex: 1;
  }

  .btn-dark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 10px 24px;
    border-radius: 3px;
    font-family: var(--font-ui);
    font-size: 20px;
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  .btn-dark:hover {
    opacity: 0.85;
  }

  .arrow {
    width: 14px;
    height: 11px;
  }
</style>
