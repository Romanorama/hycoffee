---
import { Image } from 'astro:assets';
import { reader, resolveCmsImage } from '../lib/cms';
import type { Lang } from '../lib/i18n';

interface Props {
  heading: string;
  lang?: Lang;
}

const { heading, lang = 'de' } = Astro.props;
const readLabel = lang === 'en' ? 'Read article' : 'Artikel lesen';
const moreLabel = lang === 'en' ? 'View more from in the media' : 'Mehr aus den Medien';
const pressLabel = lang === 'en' ? 'PRESS' : 'PRESSE';
const minuteLabel = lang === 'en' ? 'min' : 'Min';

const entries = await reader.collections.press.all();
const items = entries
  .map(({ slug, entry }) => ({
    slug,
    title: entry.title,
    outlet: entry.outlet,
    excerpt: lang === 'en'
      ? (entry.contentEn?.excerpt || entry.contentDe?.excerpt)
      : entry.contentDe?.excerpt,
    logoAlt: lang === 'en'
      ? (entry.contentEn?.logoAlt || entry.contentDe?.logoAlt || entry.outlet)
      : (entry.contentDe?.logoAlt || entry.outlet),
    featureImageAlt: lang === 'en'
      ? (entry.contentEn?.featureImageAlt || entry.contentDe?.featureImageAlt || `${entry.outlet} report`)
      : (entry.contentDe?.featureImageAlt || `${entry.outlet} Reportage`),
    readingTime: entry.readingTime ?? 2,
    externalLink: entry.externalLink ?? '#',
    logoImage: resolveCmsImage(entry.logoImage),
    featureImage: resolveCmsImage(entry.featureImage),
    sortOrder: entry.sortOrder ?? 0,
  }))
  .sort((a, b) => a.sortOrder - b.sortOrder || a.title.localeCompare(b.title));

const hasMobileMore = items.length > 2;
const hasDesktopMore = items.length > 4;
---

<section
  class:list={[
    'press',
    hasMobileMore && 'has-more-mobile',
    hasDesktopMore && 'has-more-desktop',
  ]}
  data-press-section
>
  <h2 class="press-heading">{heading}</h2>
  <div class="press-cards" id={`press-cards-${lang}`}>
    {
      items.map((item) => (
        <article class="press-card">
          <div class="press-card-inner">
            <span class="caption">{pressLabel}</span>
            <div class="press-divider" />
            <h3
              class:list={[
                'press-title',
                item.title.length > 22 && 'press-title-long',
                item.title.length > 30 && 'press-title-very-long',
              ]}
            >
              {item.title}
            </h3>
            {item.featureImage && (
              <div class="press-image">
                <Image
                  src={item.featureImage}
                  alt={item.featureImageAlt}
                  widths={[450, 900]}
                  sizes="(max-width: 768px) 100vw, 25vw"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <div class="press-meta">
              <div class="press-source">
                {item.logoImage && (
                  <Image
                    src={item.logoImage}
                    alt={item.logoAlt}
                    class="press-logo"
                    widths={[130, 260]}
                    sizes="130px"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </div>
              <div class="press-time">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                  <circle cx="11" cy="11" r="10" stroke="#242119" stroke-width="1" />
                  <path d="M11 6v5l3 3" stroke="#242119" stroke-width="1" stroke-linecap="round" />
                </svg>
                <span>{item.readingTime} {minuteLabel}</span>
              </div>
            </div>
            <p class="press-excerpt">{item.excerpt}</p>
            <a href={item.externalLink} class="btn btn-dark" target="_blank" rel="noopener noreferrer">
              <span>{readLabel}</span>
              <svg class="arrow" width="14" height="11" viewBox="0 0 14 11" fill="none">
                <path
                  d="M1 5.5h12m0 0L8.5 1M13 5.5L8.5 10"
                  stroke="white"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </div>
        </article>
      ))
    }
  </div>
  <button
    class="press-more-link"
    type="button"
    aria-expanded="false"
    aria-controls={`press-cards-${lang}`}
    data-press-more
  >
    <span>{moreLabel}</span>
    <span class="press-more-arrow" aria-hidden="true">›</span>
  </button>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-press-section]').forEach((section) => {
    const button = section.querySelector<HTMLButtonElement>('[data-press-more]');
    if (!button) return;

    button.addEventListener('click', () => {
      section.dataset.expanded = 'true';
      button.setAttribute('aria-expanded', 'true');
    });
  });
</script>

<style>
  .press {
    padding: 80px 60px;
    max-width: var(--container-max);
    margin: 0 auto;
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .press-heading {
    font-family: var(--font-heading);
    font-size: var(--type-heading);
    line-height: 0.94;
    letter-spacing: -1.5px;
    font-weight: 400;
    text-align: center;
    margin-bottom: 60px;
  }

  .press-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 0;
    row-gap: 64px;
  }

  .press:not([data-expanded='true']) .press-card:nth-child(n+5) {
    display: none;
  }

  .press-card {
    border-right: 1px solid var(--warm-dark-grey);
    min-height: 587px;
  }

  .press-card:nth-child(4n),
  .press-card:last-child {
    border-right: none;
  }

  .press-card-inner {
    padding: 12px 24px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .caption {
    font-family: var(--font-heading);
    font-size: var(--type-caption);
    line-height: 1.2;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--warm-dark-grey);
  }

  .press-divider {
    width: 100%;
    height: 1px;
    background: var(--warm-dark-grey);
    margin: 12px 0;
  }

  .press-title {
    --press-title-size: var(--type-copy-lg);
    --press-title-block-size: calc(var(--type-copy-lg) * 2.34);

    font-family: var(--font-ui);
    font-size: var(--press-title-size);
    line-height: 1.17;
    font-weight: 400;
    letter-spacing: 0.7px;
    color: var(--warm-dark-grey);
    margin-bottom: 16px;
    min-height: var(--press-title-block-size);
    text-wrap: balance;
  }

  .press-title-long {
    --press-title-size: clamp(18px, 0.8vw + 11px, 24px);
  }

  .press-title-very-long {
    --press-title-size: clamp(17px, 0.65vw + 10px, 22px);
  }

  .press-image {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .press-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .press-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .press-logo {
    height: 65px;
    width: auto;
  }

  .press-time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-heading);
    font-size: var(--type-copy-fluid);
    color: var(--warm-dark-grey);
  }

  .press-excerpt {
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy);
    line-height: 1.3;
    color: var(--warm-dark-grey);
    margin-bottom: 16px;
    flex: 1;
  }

  .btn-dark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 10px 24px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button);
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  .btn-dark:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .arrow {
    width: 14px;
    height: 11px;
  }

  .press-more-link {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.22em;
    margin: 54px auto 0;
    padding: 0;
    width: auto;
    border: 0;
    background: transparent;
    font-family: var(--font-ui);
    font-size: var(--type-button-lg);
    line-height: 1;
    color: var(--violet);
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.26s ease;
  }

  .press.has-more-desktop .press-more-link {
    display: inline-flex;
  }

  .press[data-expanded='true'] .press-more-link {
    display: none;
  }

  .press-more-link:hover,
  .press-more-link:focus-visible {
    opacity: 0.86;
  }

  .press-more-arrow {
    display: inline-block;
    transition: transform 0.26s ease;
  }

  .press-more-link:hover .press-more-arrow,
  .press-more-link:focus-visible .press-more-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .press {
      padding: 48px 24px;
    }

    .press-heading {
      margin-bottom: 32px;
    }

    .press-cards {
      grid-template-columns: 1fr;
      gap: 12px 0;
    }

    .press-card {
      border-right: none;
      min-height: auto;
    }

    .press:not([data-expanded='true']) .press-card:nth-child(n+3) {
      display: none;
    }

    .press-card-inner {
      padding: 12px 0;
    }

    .press-title {
      min-height: 0;
    }

    .press.has-more-mobile .press-more-link {
      display: inline-flex;
      margin-top: 22px;
      width: 100%;
    }

    .press[data-expanded='true'] .press-more-link {
      display: none;
    }

    .press-logo {
      height: 40px;
    }
  }
</style>
