---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  DEFAULT_DESCRIPTION,
  SITE_NAME,
  getBaseSchemas,
  toAbsoluteUrl,
} from '../lib/seo';
import { DEFAULT_LANG, getLocalizedPath, locales, type Lang } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: ImageMetadata | string;
  ogImageAlt?: string;
  noindex?: boolean;
  preloadImage?: ImageMetadata;
  preloadImageSizes?: string;
  preloadImageWidths?: number[];
  type?: 'website' | 'article';
  schema?: Record<string, unknown> | Record<string, unknown>[];
  publishedTime?: string;
  modifiedTime?: string;
  lang?: Lang;
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonicalPath,
  ogImage,
  ogImageAlt,
  noindex = false,
  preloadImage,
  preloadImageSizes,
  preloadImageWidths = [768, 1280, 1920],
  type = 'website',
  schema,
  publishedTime,
  modifiedTime,
  lang = DEFAULT_LANG,
} = Astro.props;

const preload = preloadImage
  ? await getImage({
      src: preloadImage,
      widths: preloadImageWidths,
      format: 'webp',
      quality: 72,
    })
  : null;

const resolvedOgImage = typeof ogImage === 'string'
  ? { src: ogImage }
  : ogImage
    ? await getImage({
        src: ogImage,
        width: 1200,
        height: 630,
        format: 'jpg',
        quality: 82,
      })
    : null;

const canonical = Astro.site
  ? new URL(canonicalPath ?? Astro.url.pathname, Astro.site).toString()
  : toAbsoluteUrl(canonicalPath ?? Astro.url.pathname);

const ogImageUrl = resolvedOgImage
  ? (resolvedOgImage.src.startsWith('http')
      ? resolvedOgImage.src
      : toAbsoluteUrl(resolvedOgImage.src))
  : null;

const robots = noindex ? 'noindex,follow' : 'index,follow';
const schemas = [...getBaseSchemas(), ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
const alternateDe = Astro.site
  ? new URL(getLocalizedPath(Astro.url.pathname, 'de'), Astro.site).toString()
  : toAbsoluteUrl(getLocalizedPath(Astro.url.pathname, 'de'));
const alternateEn = Astro.site
  ? new URL(getLocalizedPath(Astro.url.pathname, 'en'), Astro.site).toString()
  : toAbsoluteUrl(getLocalizedPath(Astro.url.pathname, 'en'));
---

<html lang={locales[lang].html}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="de" href={alternateDe} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="x-default" href={alternateDe} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={locales[lang].og} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    <link rel="preload" href="/fonts/HALTimezone-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DGMSprinter-Regular.woff2" as="font" type="font/woff2" crossorigin />
    {preload && (
      <link
        rel="preload"
        as="image"
        href={preload.src}
        imagesrcset={preload.srcSet.attribute}
        imagesizes={preloadImageSizes}
        fetchpriority="high"
      />
    )}
    <title>{title}</title>
    {schemas.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const sectionSelector = 'main section, main article';

        function getRevealItems() {
          return Array.from(document.querySelectorAll(sectionSelector)).filter((item) => {
            const parentSection = item.parentElement?.closest(sectionSelector);
            return !parentSection;
          });
        }

        function revealNow(item) {
          item.classList.add('is-visible');
        }

        function initSectionReveals() {
          const items = getRevealItems();
          if (!items.length) return;

          if (prefersReducedMotion || !('IntersectionObserver' in window)) {
            items.forEach((item) => {
              item.classList.add('scroll-reveal', 'is-visible');
            });
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                revealNow(entry.target);
                observer.unobserve(entry.target);
              });
            },
            {
              rootMargin: '0px 0px -12% 0px',
              threshold: 0.08,
            }
          );

          items.forEach((item, index) => {
            if (item.dataset.scrollRevealReady === 'true') return;
            item.dataset.scrollRevealReady = 'true';

            if (item.dataset.noScrollReveal === 'true') return;

            const rect = item.getBoundingClientRect();
            if (rect.top < window.innerHeight) return;

            item.style.setProperty('--reveal-delay', `${Math.min(index % 4, 3) * 45}ms`);
            item.classList.add('scroll-reveal');
            observer.observe(item);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initSectionReveals, { once: true });
        } else {
          initSectionReveals();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
