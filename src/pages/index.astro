---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Tiles from '../components/Tiles.astro';
import Values from '../components/Values.astro';
import Team from '../components/Team.astro';
import SpeciesDiscovery from '../components/SpeciesDiscovery.astro';
import Science from '../components/Science.astro';
import Banner from '../components/Banner.astro';
import Press from '../components/Press.astro';
import Footer from '../components/Footer.astro';
import { reader, resolveCmsImage } from '../lib/cms';

export const prerender = true;

const home = await reader.singletons.home.read();
if (!home) throw new Error('Home singleton not found');
const content = home.contentDe;

const heroImage = resolveCmsImage(home.heroImage);
if (!heroImage) throw new Error(`Hero image not found: ${home.heroImage}`);

const speciesVisible = home.speciesVisibleDe ?? false;
const speciesPhoto = speciesVisible ? resolveCmsImage(home.speciesExpandedPhoto) : null;
if (speciesVisible && !speciesPhoto) throw new Error(`Species photo not found: ${home.speciesExpandedPhoto}`);

const teamStripImages = home.teamStripImages
  .map((path, index) => {
    const image = resolveCmsImage(path);
    return image ? { image, alt: content.teamStripImageAlts?.[index] ?? '' } : null;
  })
  .filter((img): img is NonNullable<typeof img> => img !== null);

const tiles = home.tiles.map((tile, index) => ({
  category: content.tiles[index]?.category,
  heading: content.tiles[index]?.heading,
  body: content.tiles[index]?.body,
  ctaLabel: content.tiles[index]?.ctaLabel,
  ctaUrl: tile.ctaUrl,
  color: tile.color,
}));
---

<BaseLayout
  title="Klimaresilienter Rohkaffee – HyCoffee"
  description="HyCoffee verbindet klimaresilienten Rohkaffee mit fairen Lieferketten, Forschung und neuen Kaffeearten für eine widerstandsfähigere Zukunft des Kaffees."
  ogImage={heroImage}
  ogImageAlt={content.heroImageAlt || content.heroHeadline}
  preloadImage={heroImage}
  preloadImageSizes="(max-width: 768px) 100vw, 50vw"
>
  <Navigation />
  <main class="home-main">
    <div class="home-nav-underlay" aria-hidden="true"></div>
    <Hero
      headline={content.heroHeadline}
      image={heroImage}
      imageAlt={content.heroImageAlt}
      ctaLabel={content.heroCtaLabel}
      ctaUrl={home.heroCtaUrl}
    />
    <Tiles tiles={tiles} />
    <Values heading={content.valuesHeading} body={content.valuesBody} />
    <Team
      images={teamStripImages}
      blurb={content.teamBlurb}
      missionHeading={content.teamMissionHeading}
      ctaLabel={content.teamCtaLabel}
      ctaUrl="/ueber-uns"
    />
    {speciesVisible && speciesPhoto && (
      <SpeciesDiscovery
        heading={content.speciesHeading}
        photo={speciesPhoto}
        photoAlt={content.speciesExpandedPhotoAlt}
        body={content.speciesExpandedBody}
      />
    )}
    <Science
      label={content.scienceLabel}
      heading={content.scienceHeading}
      body={content.scienceBody}
      ctaLabel={content.scienceCtaLabel}
    />
    <Banner />
    <Press heading={content.pressHeading} />
  </main>
  <Footer />
</BaseLayout>

<style>
  .home-main {
    position: relative;
  }

  .home-nav-underlay {
    --home-nav-underlay-height: 278px;
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: var(--home-nav-underlay-height);
    transform: translateY(calc(-1 * var(--home-nav-underlay-height)));
    background: var(--warm-dark-grey);
    pointer-events: none;
    z-index: 0;
  }

  .home-main > :not(.home-nav-underlay) {
    position: relative;
    z-index: 1;
  }
</style>
