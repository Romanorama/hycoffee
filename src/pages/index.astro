---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Tiles from '../components/Tiles.astro';
import Values from '../components/Values.astro';
import Team from '../components/Team.astro';
import SpeciesDiscovery from '../components/SpeciesDiscovery.astro';
import Science from '../components/Science.astro';
import Banner from '../components/Banner.astro';
import Press from '../components/Press.astro';
import Footer from '../components/Footer.astro';
import { reader, resolveCmsImage } from '../lib/cms';

export const prerender = true;

const home = await reader.singletons.home.read();
if (!home) throw new Error('Home singleton not found');

const heroImage = resolveCmsImage(home.heroImage);
if (!heroImage) throw new Error(`Hero image not found: ${home.heroImage}`);

const speciesPhoto = resolveCmsImage(home.speciesExpandedPhoto);
if (!speciesPhoto) throw new Error(`Species photo not found: ${home.speciesExpandedPhoto}`);

const teamStripImages = home.teamStripImages
  .map((path) => resolveCmsImage(path))
  .filter((img): img is NonNullable<typeof img> => img !== null);

const tiles = home.tiles.map((tile) => ({
  category: tile.category,
  heading: tile.heading,
  body: tile.body,
  ctaLabel: tile.ctaLabel,
  ctaUrl: tile.ctaUrl,
  color: tile.color,
}));
---

<BaseLayout
  title="HyCoffee – Klimaresilienter Rohkaffee"
  description="HyCoffee verbindet klimaresilienten Rohkaffee mit fairen Lieferketten, Forschung und neuen Kaffeearten fuer eine widerstandsfaehigere Zukunft des Kaffees."
  ogImage={heroImage}
  ogImageAlt={home.heroHeadline}
  preloadImage={heroImage}
  preloadImageSizes="(max-width: 768px) 100vw, 50vw"
>
  <Navigation />
  <main class="home-main">
    <div class="home-nav-underlay" aria-hidden="true"></div>
    <Hero
      headline={home.heroHeadline}
      image={heroImage}
      ctaLabel={home.heroCtaLabel}
      ctaUrl={home.heroCtaUrl}
    />
    <Tiles tiles={tiles} />
    <Values heading={home.valuesHeading} body={home.valuesBody} />
    <Team
      images={teamStripImages}
      blurb={home.teamBlurb}
      missionHeading={home.teamMissionHeading}
      ctaLabel={home.teamCtaLabel}
    />
    <SpeciesDiscovery
      heading={home.speciesHeading}
      photo={speciesPhoto}
      body={home.speciesExpandedBody}
    />
    <Science
      label={home.scienceLabel}
      heading={home.scienceHeading}
      body={home.scienceBody}
      ctaLabel={home.scienceCtaLabel}
    />
    <Banner />
    <Press heading={home.pressHeading} />
  </main>
  <Footer />
</BaseLayout>

<style>
  .home-main {
    position: relative;
  }

  .home-nav-underlay {
    --home-nav-underlay-height: 278px;
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: var(--home-nav-underlay-height);
    transform: translateY(calc(-1 * var(--home-nav-underlay-height)));
    background: var(--warm-dark-grey);
    pointer-events: none;
    z-index: 0;
  }

  .home-main > :not(.home-nav-underlay) {
    position: relative;
    z-index: 1;
  }
</style>
