---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Tiles from '../components/Tiles.astro';
import Values from '../components/Values.astro';
import Team from '../components/Team.astro';
import SpeciesDiscovery from '../components/SpeciesDiscovery.astro';
import Science from '../components/Science.astro';
import Banner from '../components/Banner.astro';
import Press from '../components/Press.astro';
import Footer from '../components/Footer.astro';
import heroImage from '../assets/images/hero.webp';
---

<BaseLayout
  title="HyCoffee – Klimaresilienter Rohkaffee"
  preloadImage={heroImage}
  preloadImageSizes="(max-width: 768px) 100vw, 50vw"
>
  <Navigation />
  <main class="home-main">
    <div class="home-nav-underlay" aria-hidden="true"></div>
    <Hero />
    <Tiles />
    <Values />
    <Team />
    <SpeciesDiscovery />
    <Science />
    <Banner />
    <Press />
  </main>
  <Footer />
</BaseLayout>

<style>
  .home-main {
    position: relative;
  }

  .home-nav-underlay {
    --home-nav-underlay-height: 278px;
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: var(--home-nav-underlay-height);
    transform: translateY(calc(-1 * var(--home-nav-underlay-height)));
    background: var(--warm-dark-grey);
    pointer-events: none;
    z-index: 0;
  }

  .home-main > :not(.home-nav-underlay) {
    position: relative;
    z-index: 1;
  }
</style>
