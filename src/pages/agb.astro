---
import LegalPage from '../components/LegalPage.astro';
import { reader } from '../lib/cms';

export const prerender = true;

const data = await reader.singletons.agb.read();
if (!data) throw new Error('AGB singleton not found');
---

<LegalPage
  title="AGB – HyCoffee"
  description="Allgemeine Geschäftsbedingungen von HyCoffee."
  heading={data.heading}
  sections={data.sections}
  noindex={true}
/>
