    will-change: height;
  }

  .table-row-wrapper.is-animating .row-details {
    pointer-events: none;
    will-change: opacity, transform;
  }

</style>

<script is:inline>
  // Animate accordion rows slowly while keeping the clicked row anchored.
  document.querySelectorAll('.table-row-wrapper').forEach(wrapper => {
    const summary = wrapper.querySelector('summary.table-row');
    const details = wrapper.querySelector('.row-details');
    const duration = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 1 : 1000;
    const easing = 'cubic-bezier(0.16, 1, 0.3, 1)';
    if (!summary || !details) return;
    let activeAnimation = null;
    let activeDetailAnimation = null;

    function cleanup() {
      wrapper.style.height = '';
      wrapper.style.overflow = '';
      wrapper.classList.remove('is-animating');
      activeAnimation = null;
      activeDetailAnimation = null;
    }

    function keepSummaryAnchored(beforeTop) {
      const afterTop = summary.getBoundingClientRect().top;
      const delta = afterTop - beforeTop;
      if (delta === 0) return;
      const prev = document.documentElement.style.scrollBehavior;
      document.documentElement.style.scrollBehavior = 'auto';
      window.scrollBy(0, delta);
      document.documentElement.style.scrollBehavior = prev;
    }

    function animateRow(open) {
      if (activeAnimation) return;

      if (!wrapper.animate || !details.animate) {
        wrapper.open = open;
        return;
      }

      const beforeTop = summary.getBoundingClientRect().top;
      const startHeight = wrapper.offsetHeight;

      wrapper.style.height = `${startHeight}px`;
      wrapper.style.overflow = 'hidden';
      wrapper.classList.add('is-animating');
      wrapper.getBoundingClientRect();

      if (open) wrapper.open = true;

      const endHeight = open
        ? summary.offsetHeight + details.offsetHeight
        : summary.offsetHeight;

      try {
        activeDetailAnimation = details.animate(
          [
            {
              opacity: open ? 0 : 1,
              transform: open ? 'translateY(-6px)' : 'translateY(0)'
            },
            {
              opacity: open ? 1 : 0,
              transform: open ? 'translateY(0)' : 'translateY(-6px)'
            }
          ],
          {
            duration,
            easing,
            fill: 'both'
          }
        );

        activeAnimation = wrapper.animate(
          [
            { height: `${startHeight}px` },
            { height: `${endHeight}px` }
          ],
          {
            duration,
            easing,
            fill: 'both'
          }
        );
      } catch (error) {
        wrapper.open = open;
        cleanup();
        return;
      }

      activeAnimation.onfinish = () => {
        wrapper.open = open;
        if (activeDetailAnimation) activeDetailAnimation.cancel();
        cleanup();
        keepSummaryAnchored(beforeTop);
      };

      activeAnimation.oncancel = cleanup;
    }

    summary.addEventListener('click', event => {
      const target = event.target;
      if (target instanceof Element && target.closest('button, a')) return;
      event.preventDefault();
      animateRow(!wrapper.open);
    });
  });

  document.querySelectorAll('.table-row-wrapper').forEach(wrapper => {
    wrapper.addEventListener('toggle', (e) => {
      if (!wrapper.classList.contains('is-animating')) return;
      e.stopPropagation();
    });
  });

  (() => {
    const popup = document.querySelector('[data-sample-popup]');
    const popupPanel = popup?.querySelector('.sample-popup-panel');
    let lastFocusedElement = null;

    function getFocusableItems() {
      if (!popupPanel) return [];
      return Array.from(
        popupPanel.querySelectorAll('a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])')
      );
    }

    function openPopup() {
      if (!popup || !popupPanel) return;
      lastFocusedElement = document.activeElement;
      popup.hidden = false;
      document.body.classList.add('has-sample-popup');
      requestAnimationFrame(() => popupPanel.focus());
    }

    function closePopup() {
      if (!popup) return;
      popup.hidden = true;
      document.body.classList.remove('has-sample-popup');
      if (lastFocusedElement instanceof HTMLElement) lastFocusedElement.focus();
    }

    document.querySelectorAll('[data-sample-action], [data-sample-checkout]').forEach(control => {
      control.addEventListener('click', event => {
        if (control.dataset.sampleSoldOut !== 'true') return;
        event.preventDefault();
        event.stopPropagation();
        openPopup();
      });
    });

    popup?.querySelectorAll('[data-sample-popup-close]').forEach(control => {
      control.addEventListener('click', closePopup);
    });

    document.addEventListener('keydown', event => {
      if (!popup || popup.hidden) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        closePopup();
        return;
      }

      if (event.key !== 'Tab') return;

      const focusableItems = getFocusableItems();
      if (!focusableItems.length) return;

      const firstItem = focusableItems[0];
      const lastItem = focusableItems[focusableItems.length - 1];

      if (event.shiftKey && document.activeElement === firstItem) {
        event.preventDefault();
        lastItem.focus();
      } else if (!event.shiftKey && document.activeElement === lastItem) {
        event.preventDefault();
        firstItem.focus();
      }
    });
  })();

  (() => {
    const requestPopup = document.querySelector('[data-sample-request-popup]');
    if (!requestPopup) return;

    const requestPanel = requestPopup.querySelector('.sample-popup-panel-request');
    const form = requestPopup.querySelector('[data-sample-request-form]');
    const selectionEl = requestPopup.querySelector('[data-sample-request-selection]');
    const selectedInput = requestPopup.querySelector('[data-selected-samples-input]');
    const statusEl = requestPopup.querySelector('[data-sample-request-status]');
    const submitBtn = requestPopup.querySelector('[data-sample-request-submit]');
    const checkoutBtn = document.querySelector('[data-sample-checkout]');
    const checkoutCount = document.querySelector('.checkout-count');

    const cart = new Map();
    let lastFocused = null;

    function syncButtons() {
      document.querySelectorAll('[data-sample-action]').forEach(button => {
        if (button.dataset.sampleSoldOut === 'true') return;
        const slug = button.dataset.sampleSlug;
        const isActive = slug ? cart.has(slug) : false;
        button.classList.toggle('is-active', isActive);
        const plus = button.querySelector('.sample-plus');
        const text = button.querySelector('.sample-text');
        if (plus) plus.textContent = isActive ? '✓' : '+';
        const root = document.querySelector('.shop');
        const addSampleLabel = root?.dataset.addSampleLabel || 'Add Sample';
        const addedSampleLabel = root?.dataset.addedSampleLabel || 'Added';
        if (text) text.textContent = isActive ? addedSampleLabel : addSampleLabel;
      });
    }

    function syncCheckout() {
      const count = cart.size;
      if (checkoutCount) {
        const root = document.querySelector('.shop');
        const emptyLabel = root?.dataset.checkoutEmptyLabel || '0 samples added';
        const singleLabel = root?.dataset.checkoutSingleLabel || '1 sample added';
        const multipleLabel = root?.dataset.checkoutMultipleLabel || '{count} samples added';
        checkoutCount.textContent = count === 0
          ? emptyLabel
          : count === 1
            ? singleLabel
            : multipleLabel.replace('{count}', count);
      }
      if (checkoutBtn) {
        checkoutBtn.classList.toggle('is-disabled', count === 0);
        checkoutBtn.setAttribute('aria-disabled', count === 0 ? 'true' : 'false');
      }
    }

    function toggleCart(slug, name) {
      if (!slug) return;
      if (cart.has(slug)) {
        cart.delete(slug);
      } else {
        cart.set(slug, name || slug);
      }
      syncButtons();
      syncCheckout();
    }

    function openRequestPopup() {
      if (cart.size === 0 || !requestPanel) return;
      const names = Array.from(cart.values()).join(', ');
      const slugs = Array.from(cart.keys()).join(', ');
      if (selectionEl) selectionEl.textContent = names;
      if (selectedInput) selectedInput.value = slugs;
      if (statusEl) {
        statusEl.textContent = '';
        statusEl.classList.remove('is-error');
      }
      lastFocused = document.activeElement;
      requestPopup.hidden = false;
      document.body.classList.add('has-sample-popup');
      requestAnimationFrame(() => requestPanel.focus());
    }

    function closeRequestPopup() {
      requestPopup.hidden = true;
      document.body.classList.remove('has-sample-popup');
      if (lastFocused instanceof HTMLElement) lastFocused.focus();
    }

    document.querySelectorAll('[data-sample-action]').forEach(button => {
      if (button.dataset.sampleSoldOut === 'true') return;
      button.addEventListener('click', event => {
        event.preventDefault();
        event.stopPropagation();
        toggleCart(button.dataset.sampleSlug, button.dataset.sampleName);
      });
    });

    if (checkoutBtn) {
      checkoutBtn.addEventListener('click', event => {
        if (checkoutBtn.dataset.sampleSoldOut === 'true') return;
        event.preventDefault();
        if (cart.size === 0) return;
        openRequestPopup();
      });
    }

    requestPopup.querySelectorAll('[data-sample-request-close]').forEach(control => {
      control.addEventListener('click', closeRequestPopup);
    });

    document.addEventListener('keydown', event => {
      if (requestPopup.hidden) return;
      if (event.key === 'Escape') {
        event.preventDefault();
        closeRequestPopup();
      }
    });

    if (form) {
      form.addEventListener('submit', async event => {
        event.preventDefault();
        if (!submitBtn || !statusEl) return;
        submitBtn.setAttribute('disabled', 'true');
        statusEl.classList.remove('is-error');
        statusEl.textContent = 'Sending...';

        const data = new FormData(form);
        const body = new URLSearchParams();
        data.forEach((value, key) => body.append(key, String(value)));

        try {
          const response = await fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: body.toString(),
          });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          statusEl.textContent = 'Thank you. We will get back to you shortly.';
          form.reset();
          cart.clear();
          syncButtons();
          syncCheckout();
        } catch (err) {
          statusEl.classList.add('is-error');
          statusEl.textContent = 'Sending failed. Please try again or contact us directly.';
        } finally {
          submitBtn.removeAttribute('disabled');
        }
      });
    }

    syncCheckout();
  })();

</script>
