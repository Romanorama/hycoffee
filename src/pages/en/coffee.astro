---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import SampleRow from '../../components/SampleRow.astro';
import { reader, resolveCmsImage } from '../../lib/cms';

export const prerender = true;

const page = await reader.singletons.kaffee.read();
if (!page) throw new Error('Kaffee singleton not found');

const allSamples = await reader.collections.kaffeeSamples.all();
const samples = allSamples
  .filter((entry) => entry.entry.available)
  .sort((a, b) => (a.entry.sortOrder ?? 0) - (b.entry.sortOrder ?? 0))
  .map(({ slug, entry }) => ({
    slug,
    ...entry,
    heroImage: resolveCmsImage(entry.heroImage),
  }));

const samplesSoldOut = page.samplesSoldOut;
const pageContent = page.contentEn;
const fallbackPageContent = page.contentDe;
const pageHeading = pageContent.pageHeading || fallbackPageContent.pageHeading;
const pageIntro = pageContent.pageIntro || fallbackPageContent.pageIntro;
const contentLabel = (key: keyof typeof pageContent) => pageContent[key] || fallbackPageContent[key] || '';
const checkoutCopy = samplesSoldOut ? contentLabel('checkoutSoldOutLabel') : contentLabel('checkoutEmptyLabel');
const seoDescription =
  'Explore HyCoffee samples from Uganda: expressive Arabicas from regenerative systems and Excelsa as a climate-resilient alternative with its own sensory profile.';
const seoImage = samples.find((sample) => sample.heroImage)?.heroImage ?? undefined;
const soldOutPopup = {
  kicker: pageContent.soldOutPopupKicker || fallbackPageContent.soldOutPopupKicker,
  title: pageContent.soldOutPopupTitle || fallbackPageContent.soldOutPopupTitle,
  copy: pageContent.soldOutPopupCopy || fallbackPageContent.soldOutPopupCopy,
  primaryLabel: pageContent.soldOutPopupPrimaryLabel || fallbackPageContent.soldOutPopupPrimaryLabel,
  primaryHref: pageContent.soldOutPopupPrimaryHref || fallbackPageContent.soldOutPopupPrimaryHref,
};
---

<BaseLayout
  lang="en"
  title="Buy coffee – HyCoffee"
  description={seoDescription}
  ogImage={seoImage}
  ogImageAlt="Climate-resilient coffee samples from HyCoffee"
>
  <Navigation lang="en" />
  <main
    class="shop"
    data-add-sample-label={contentLabel('addSampleLabel')}
    data-added-sample-label={contentLabel('addedSampleLabel')}
    data-checkout-empty-label={contentLabel('checkoutEmptyLabel')}
    data-checkout-single-label={contentLabel('checkoutSingleLabel')}
    data-checkout-multiple-label={contentLabel('checkoutMultipleLabel')}
  >
    <!-- Yellow offer layout v2: no image, table anchored at bottom -->
    <section class="shop-offer-alt" aria-labelledby="shop-offer-title">
      <div class="shop-offer-copy">
        <h1 id="shop-offer-title" class="shop-offer-heading">{pageHeading}</h1>
        <p class="shop-offer-intro">{pageIntro}</p>
      </div>
    </section>

    <!-- Table -->
    <section class="shop-table">
      <div class="table-header">
        <span class="col col-name">{contentLabel('tableNameLabel')}</span>
        <span class="col col-species">{contentLabel('tableSpeciesLabel')}</span>
        <span class="col col-country">{contentLabel('tableCountryLabel')}</span>
        <span class="col col-score">{contentLabel('tableScoreLabel')}</span>
        <span class="col col-process">{contentLabel('tableProcessLabel')}</span>
        <span class="col col-action"></span>
      </div>

      {samples.map((sample) => (
        <SampleRow
          slug={sample.slug}
          name={sample.name}
          species={sample.species}
          country={sample.country}
          score={sample.score}
          process={sample.process}
          variety={sample.variety}
          harvest={sample.harvest}
          region={sample.region}
          altitude={sample.altitude}
          flavourNotes={sample.flavourNotes}
          intro={sample.contentEn.intro || sample.contentDe.intro}
          resilienceText={sample.contentEn.resilienceText || sample.contentDe.resilienceText}
          socialText={sample.contentEn.socialText || sample.contentDe.socialText}
          heroImage={sample.heroImage}
          pdfDownloadHref={sample.pdfDownload}
          samplesSoldOut={samplesSoldOut}
          lang="en"
          addSampleLabel={contentLabel('addSampleLabel')}
          soldOutLabel={contentLabel('soldOutLabel')}
          soldOutAriaLabel={contentLabel('checkoutSoldOutLabel')}
          productSheetLabel={contentLabel('productSheetLabel')}
        />
      ))}
    </section>

    <!-- Checkout Bar -->
    <div class="checkout-spacer">
      <section class="checkout-bar" data-no-scroll-reveal="true">
        <div class="checkout-inner">
          <p class="checkout-count">{checkoutCopy}</p>
          <a href="#" class="btn-checkout" data-sample-checkout data-sample-sold-out={samplesSoldOut ? 'true' : 'false'}>
            <span>{contentLabel('checkoutButtonLabel')}</span>
            <svg class="arrow" width="14" height="11" viewBox="0 0 14 11" fill="none">
              <path d="M1 5.5h12m0 0L8.5 1M13 5.5L8.5 10" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </section>
    </div>

    {!samplesSoldOut && (
      <div class="sample-popup sample-popup-request" data-sample-request-popup hidden>
        <button type="button" class="sample-popup-backdrop" data-sample-request-close aria-label="Close popup"></button>
        <aside class="sample-popup-panel sample-popup-panel-request" role="dialog" aria-modal="true" aria-labelledby="sample-request-title" tabindex="-1">
          <button type="button" class="sample-popup-close" data-sample-request-close aria-label="Close popup">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </button>
          <p class="sample-popup-kicker">Sample request</p>
          <h2 id="sample-request-title" class="sample-popup-title">Your selection</h2>
          <p class="sample-request-selection" data-sample-request-selection></p>
          <form
            class="sample-request-form"
            name="sample-request"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            data-sample-request-form
          >
            <input type="hidden" name="form-name" value="sample-request" />
            <p class="sample-request-honeypot"><label>Please leave empty: <input name="bot-field" /></label></p>
            <input type="hidden" name="selectedSamples" data-selected-samples-input />
            <label class="sample-request-field">
              <span>Full name *</span>
              <input type="text" name="fullName" required autocomplete="name" />
            </label>
            <label class="sample-request-field">
              <span>Company</span>
              <input type="text" name="company" autocomplete="organization" />
            </label>
            <label class="sample-request-field">
              <span>Email *</span>
              <input type="email" name="email" required autocomplete="email" />
            </label>
            <label class="sample-request-field">
              <span>Phone</span>
              <input type="tel" name="phone" autocomplete="tel" />
            </label>
            <label class="sample-request-field">
              <span>Shipping address *</span>
              <textarea name="shippingAddress" rows="3" required autocomplete="street-address"></textarea>
            </label>
            <label class="sample-request-field">
              <span>Message</span>
              <textarea name="message" rows="3"></textarea>
            </label>
            <p class="sample-request-status" data-sample-request-status role="status" aria-live="polite"></p>
            <div class="sample-popup-actions sample-request-actions">
              <button type="submit" class="sample-popup-primary" data-sample-request-submit>
                <span>Send sample request</span>
              </button>
              <button type="button" class="sample-popup-secondary" data-sample-request-close>
                <span>Close</span>
              </button>
            </div>
          </form>
        </aside>
      </div>
    )}

    {samplesSoldOut && (
      <div class="sample-popup" data-sample-popup hidden>
        <button type="button" class="sample-popup-backdrop" data-sample-popup-close aria-label="Close popup"></button>
        <aside class="sample-popup-panel" role="dialog" aria-modal="true" aria-labelledby="sample-popup-title" aria-describedby="sample-popup-copy" tabindex="-1">
          <button type="button" class="sample-popup-close" data-sample-popup-close aria-label="Close popup">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </button>
          <p class="sample-popup-kicker">{soldOutPopup.kicker}</p>
          <h2 id="sample-popup-title" class="sample-popup-title">{soldOutPopup.title}</h2>
          <p id="sample-popup-copy" class="sample-popup-copy">{soldOutPopup.copy}</p>
          <div class="sample-popup-actions">
            <a class="sample-popup-primary" href={soldOutPopup.primaryHref}>
              <span>{soldOutPopup.primaryLabel}</span>
            </a>
            <button type="button" class="sample-popup-secondary" data-sample-popup-close>
              <span>Close</span>
            </button>
          </div>
        </aside>
      </div>
    )}

  </main>
</BaseLayout>

<style>
  .shop {
    display: flex;
    flex-direction: column;
    height: calc(100svh - var(--nav-height, 88px) + 25px);
    min-height: 0;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .shop-offer-alt {
    --shop-offer-bg: var(--yellow);
    --shop-offer-fg: var(--warm-dark-grey);
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    background: var(--shop-offer-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(36px, 6vh, 72px) 60px;
    border-bottom: 1px solid var(--warm-dark-grey);
    transition: background-color 0.25s ease, color 0.25s ease;
  }

  .shop-offer-copy {
    width: min(1180px, 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(28px, 5vh, 48px);
  }

  .shop-offer-heading {
    font-family: var(--font-heading);
    font-size: 72px;
    line-height: 0.92;
    letter-spacing: 0;
    font-weight: 400;
    color: var(--shop-offer-fg);
    max-width: 780px;
  }

  .shop-offer-intro {
    font-family: var(--font-heading);
    font-size: 32px;
    line-height: 1.08;
    letter-spacing: 0;
    color: var(--shop-offer-fg);
    max-width: 1220px;
  }

  .shop-table {
    flex: 0 0 auto;
  }

  .table-header {
    min-height: 66px;
    align-items: center;
  }

  .table-row {
    min-height: 82px;
    padding-top: 0;
    padding-bottom: 0;
  }

  .checkout-spacer {
    flex-basis: 92px;
  }

  /* Table */
  .shop-table {
    width: 100%;
    position: relative;
    z-index: 1;
    background: var(--white);
    overflow-anchor: none;
  }

  .table-row-wrapper {
    overflow-anchor: none;
  }

  .table-header {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 0.8fr 1fr 300px;
    padding: 16px 60px;
    background: var(--warm-dark-grey);
    justify-items: start;
  }

  .table-header .col-action {
    justify-self: end;
  }

  .table-header .col {
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 1.8px;
    color: #f5f5f5;
    text-align: left;
  }

  .table-row-wrapper {
    border-top: 1px solid var(--warm-dark-grey);
  }

  .table-row {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 0.8fr 1fr 300px;
    padding: 0 60px;
    background: var(--white);
    align-items: center;
    justify-items: start;
    cursor: pointer;
    list-style: none;
  }

  .table-row .col-action {
    justify-self: end;
  }

  .table-row::-webkit-details-marker {
    display: none;
  }

  .table-row:hover {
    background: var(--warm-grey-light);
  }

  .table-row-wrapper[open] .table-row {
    background: var(--warm-grey-light);
  }

  .table-row-wrapper[open] .row-arrow {
    transform: rotate(90deg);
  }

  .cell {
    font-family: var(--font-heading);
    font-size: var(--type-copy-fluid);
    line-height: 1.2;
    color: var(--warm-dark-grey);
    text-align: left;
  }

  .col-name {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .availability-dot {
    width: 12px;
    height: 12px;
    border-radius: var(--radius-round);
    background: #8edf8e;
    flex-shrink: 0;
    margin-right: 4px;
    box-shadow: 0 0 8px 3px rgba(142, 223, 142, 0.5);
    position: relative;
    top: 2px;
    left: -4px;
    transition: all 0.4s ease;
  }

  .table-row-wrapper[open] .availability-dot {
    width: 7px;
    height: 7px;
    left: -12px;
    box-shadow: 0 0 5px 2px rgba(142, 223, 142, 0.4);
  }

  .row-arrow {
    font-size: var(--type-copy-fluid);
    margin-right: 4px;
    transition: transform 0.2s ease;
    display: inline-block;
  }

  /* Row details */
  .row-details {
    background: var(--warm-grey-light);
    border-top: 1px solid var(--light-grey);
    padding: 28px 60px 0;
  }

  .row-hero {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-media);
    aspect-ratio: 4 / 3;
    background: var(--light-grey);
  }

  .row-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .detail-intro {
    font-family: var(--font-heading);
    font-size: var(--type-copy-detail);
    line-height: 1.5;
    color: var(--warm-dark-grey);
    padding: 0;
    max-width: calc(50% - 24px);
  }

  .row-specs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px;
    border-bottom: 1px solid rgba(36, 33, 25, 0.12);
    margin: 32px 0 0;
    padding: 0 0 20px;
  }

  .spec {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .spec-label {
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(36, 33, 25, 0.55);
  }

  .spec-value {
    font-family: var(--font-heading);
    font-size: var(--type-copy-detail);
    line-height: 1.3;
    color: var(--warm-dark-grey);
  }

  .row-details-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
    padding: 24px 0 32px;
    align-items: start;
  }

  .detail-label {
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--warm-dark-grey);
    margin-bottom: 8px;
    font-weight: 400;
  }

  .detail-text {
    font-family: var(--font-heading);
    font-size: var(--type-copy-detail);
    line-height: 1.4;
    color: var(--warm-dark-grey);
  }

  .btn-sample {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    padding: 8px 16px;
    border: 1px solid var(--warm-dark-grey);
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    letter-spacing: 0.42px;
    cursor: pointer;
    transition: filter 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
  }

  .btn-sample.is-sold-out {
    background: var(--yellow);
    color: var(--warm-dark-grey);
  }

  .btn-sample.is-active {
    background: var(--warm-dark-grey);
    color: var(--white);
  }

  .btn-checkout.is-disabled {
    opacity: 0.45;
    pointer-events: none;
    cursor: not-allowed;
  }

  .sample-popup-panel-request {
    width: min(560px, 100%);
    max-height: calc(100vh - 64px);
    overflow-y: auto;
  }

  .sample-request-selection {
    margin-top: 16px;
    font-family: var(--font-heading);
    font-size: var(--type-copy-fluid);
    line-height: 1.3;
    color: var(--warm-dark-grey);
  }

  .sample-request-form {
    margin-top: 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .sample-request-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--warm-dark-grey);
  }

  .sample-request-field input,
  .sample-request-field textarea {
    font-family: var(--font-heading);
    font-size: var(--type-copy-fluid);
    line-height: 1.25;
    letter-spacing: 0;
    text-transform: none;
    color: var(--warm-dark-grey);
    background: var(--white);
    border: 1px solid var(--warm-dark-grey);
    border-radius: var(--radius-control);
    padding: 10px 14px;
    outline: none;
  }

  .sample-request-field input:focus,
  .sample-request-field textarea:focus {
    box-shadow: 0 0 0 2px rgba(36, 33, 25, 0.18);
  }

  .sample-request-field textarea {
    resize: vertical;
    min-height: 72px;
  }

  .sample-request-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .sample-request-status {
    margin: 4px 0 0;
    min-height: 1.2em;
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    letter-spacing: 0.42px;
    color: var(--warm-dark-grey);
  }

  .sample-request-status.is-error {
    color: #b3261e;
  }

  .sample-request-actions {
    margin-top: 8px;
  }

  .sample-popup-primary[disabled] {
    opacity: 0.6;
    pointer-events: none;
  }

  .btn-sample:hover,
  .btn-download-row:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .btn-download-row:hover {
    text-shadow: var(--button-text-hover-glow);
  }

  .sample-plus {
    font-size: var(--type-copy-fluid);
    letter-spacing: 0.6px;
  }

  .btn-sample.is-sold-out .sample-plus {
    width: 15px;
    height: 15px;
    border: 1px solid currentColor;
    border-radius: var(--radius-round);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-size: 10px;
    line-height: 1;
  }

  .btn-sample span:not(.sample-plus) {
    transform: translateY(1px);
  }

  .col-action {
    display: flex;
    align-items: stretch;
    gap: 8px;
  }

  .btn-download-row {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--black);
    color: var(--white);
    padding: 8px 16px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    letter-spacing: 0.42px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .btn-download-row span {
    transform: translateY(1px);
  }

  /* Checkout */
  .checkout-spacer {
    flex: 0 0 92px;
    position: sticky;
    bottom: 0;
    z-index: 2;
    background: var(--white);
    border-top: 1px solid var(--warm-dark-grey);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .checkout-bar {
    width: 100%;
    padding: 16px 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .checkout-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .checkout-count {
    font-family: var(--font-ui);
    font-size: var(--type-copy-fluid);
    letter-spacing: 1.03px;
    color: var(--warm-dark-grey);
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--black);
    color: var(--white);
    padding: 10px 20px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .btn-download:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
    text-shadow: var(--button-text-hover-glow);
  }

  .btn-checkout {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 36px;
    background: var(--black);
    color: var(--white);
    padding: 0 20px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    line-height: 1;
    transition: opacity 0.2s;
  }

  .btn-checkout span {
    transform: translateY(1px);
  }

  .btn-checkout:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
    text-shadow: var(--button-text-hover-glow);
  }

  .arrow {
    width: 14px;
    height: 11px;
  }

  .row-details-actions {
    display: none;
  }

  .sample-popup[hidden] {
    display: none;
  }

  .sample-popup {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: 24px;
  }

  .sample-popup-backdrop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: rgba(36, 33, 25, 0.5);
    backdrop-filter: blur(8px);
  }

  .sample-popup-panel {
    position: relative;
    z-index: 1;
    width: min(520px, 100%);
    background: var(--yellow);
    color: var(--warm-dark-grey);
    border: 1px solid var(--warm-dark-grey);
    border-radius: var(--radius-media);
    padding: clamp(28px, 4vw, 44px);
    box-shadow: 0 22px 70px rgba(36, 33, 25, 0.25);
  }

  .sample-popup-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--warm-dark-grey);
    border: 1px solid currentColor;
    border-radius: var(--radius-control);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .sample-popup-close:hover {
    background: var(--warm-dark-grey);
    color: var(--white);
    transform: scale(1.02);
    text-shadow: var(--button-text-hover-glow);
  }

  .sample-popup-kicker {
    font-family: var(--font-ui);
    font-size: var(--type-label);
    letter-spacing: 1.8px;
    text-transform: uppercase;
    margin-bottom: 18px;
  }

