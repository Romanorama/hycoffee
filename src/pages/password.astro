---
export const prerender = true;

const redirectParam = Astro.url.searchParams.get('redirect') ?? '/';
const error = Astro.url.searchParams.get('error') === '1';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preload" href="/fonts/HALTimezone-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DGMSprinter-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <title>HyCoffee — Currently relaunching</title>
    <style is:global>
      @font-face {
        font-family: 'HAL Timezone';
        src: url('/fonts/HALTimezone-Regular.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'DGM Sprinter';
        src: url('/fonts/DGMSprinter-Regular.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      :root {
        --warm-grey-light: #fbf8f2;
        --warm-dark-grey: #242119;
        --green: #3a563b;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        min-height: 100vh;
        background: var(--warm-grey-light);
        color: var(--warm-dark-grey);
        font-family: 'DGM Sprinter', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }

      .gate {
        width: 100%;
        max-width: 460px;
        text-align: center;
      }

      .gate h1 {
        font-family: 'HAL Timezone', sans-serif;
        font-weight: 400;
        font-size: clamp(32px, 4vw + 16px, 56px);
        line-height: 1.05;
        margin: 0 0 20px;
      }

      .gate p {
        font-size: 16px;
        line-height: 1.5;
        margin: 0 0 32px;
        opacity: 0.85;
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      input[type='password'] {
        width: 100%;
        padding: 14px 16px;
        font: inherit;
        font-size: 16px;
        background: transparent;
        color: var(--warm-dark-grey);
        border: 1px solid var(--warm-dark-grey);
        border-radius: 0;
        outline: none;
      }

      input[type='password']:focus {
        border-color: var(--green);
      }

      button {
        padding: 14px 16px;
        font: inherit;
        font-size: 16px;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        background: var(--warm-dark-grey);
        color: var(--warm-grey-light);
        border: 1px solid var(--warm-dark-grey);
        cursor: pointer;
        transition: background 120ms ease, color 120ms ease;
      }

      button:hover {
        background: var(--green);
        border-color: var(--green);
      }

      .error {
        margin-top: 14px;
        font-size: 14px;
        color: #a8341a;
      }
    </style>
  </head>
  <body>
    <main class="gate">
      <h1>Currently relaunching</h1>
      <p>HyCoffee is being relaunched. Please enter the password to preview the site.</p>

      <form method="post" action="/api/login" autocomplete="off">
        <input
          type="password"
          name="password"
          placeholder="Password"
          required
          autofocus
          aria-label="Password"
        />
        <input type="hidden" name="redirect" value={redirectParam} />
        <button type="submit">Enter</button>
        {error && <div class="error">Wrong password. Please try again.</div>}
      </form>
    </main>
  </body>
</html>
