<style>
  .wissen {
    background: var(--warm-grey-light);
    border-top: 1px solid var(--warm-dark-grey);
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .wissen-header {
    padding: 40px 32px 0;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .sort-label {
    font-family: var(--font-heading);
    font-size: 20.9px;
    line-height: 16.32px;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--warm-dark-grey);
    margin-bottom: 16px;
  }

  .filter-tags {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .filter-tag {
    font-family: var(--font-heading);
    font-size: 20.9px;
    line-height: 16.32px;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    padding: 14px 20px;
    border-radius: 8px;
    border: 1px solid var(--warm-dark-grey);
    background: transparent;
    color: var(--warm-dark-grey);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .filter-tag:hover {
    background: var(--warm-dark-grey);
    color: var(--light-grey);
  }

  .filter-tag.active {
    background: var(--warm-dark-grey);
    color: var(--light-grey);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    padding: 0 32px 60px;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .science-card {
    background: var(--warm-dark-grey);
    border-radius: 10px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    min-height: 655px;
  }

  .card-category {
    font-family: var(--font-heading);
    font-size: 20.9px;
    line-height: 16.32px;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--light-grey);
    margin-bottom: 16px;
  }

  .card-image {
    background: #d9d9d9;
    border-radius: 4px;
    flex: 1;
    min-height: 260px;
    margin-bottom: 24px;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 40px;
    line-height: 45.76px;
    font-weight: 400;
    color: var(--light-grey);
    margin-bottom: 8px;
  }

  .card-subtitle {
    font-family: var(--font-heading);
    font-size: 23px;
    line-height: 26px;
    color: var(--light-grey);
    margin-bottom: 24px;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--light-grey);
    font-family: var(--font-heading);
    font-size: 23px;
  }

  .btn-tertiary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    padding: 10px 24px;
    border-radius: 3px;
    font-family: var(--font-ui);
    font-size: 20px;
    transition: opacity 0.2s;
  }

  .btn-tertiary:hover {
    opacity: 0.85;
  }

  .arrow {
    width: 14px;
    height: 11px;
  }
</style>
