---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import wissen1 from '../../assets/images/wissen-1.jpeg';
import wissen2 from '../../assets/images/wissen-2.jpeg';
import wissen3 from '../../assets/images/wissen-3.jpeg';
import wissen4 from '../../assets/images/wissen-4.jpeg';
import wissen5 from '../../assets/images/wissen-5.jpeg';
import wissen6 from '../../assets/images/wissen-6.jpeg';

interface ArticleCard {
  category: string;
  title: string;
  subtitle: string;
  readingTime: string;
  image: ImageMetadata;
}

const articles: ArticleCard[] = [
  {
    category: 'Klimawandel',
    title: 'Wie Hitze den Arabica-Anbau veraendert',
    subtitle: 'Warum steigende Durchschnittstemperaturen die Hoehenlagen neu definieren.',
    readingTime: '5 Min',
    image: wissen1,
  },
  {
    category: 'Klimaresilienter Kaffee',
    title: 'Agroforst als Antwort auf Trockenstress',
    subtitle: 'Schattenbaeume stabilisieren Ertraege und verbessern die Bodenfeuchte.',
    readingTime: '7 Min',
    image: wissen2,
  },
  {
    category: 'Excelsa',
    title: 'Excelsa im Cupping: Fruchtig und wuerzig',
    subtitle: 'Ein Blick auf Geschmack, Struktur und Blend-Potenzial fuer Roestereien.',
    readingTime: '6 Min',
    image: wissen3,
  },
  {
    category: 'Klimawandel',
    title: 'Wasserknappheit in Ostafrika',
    subtitle: 'Welche Regionen besonders betroffen sind und welche Strategien greifen.',
    readingTime: '4 Min',
    image: wissen4,
  },
  {
    category: 'Klimaresilienter Kaffee',
    title: 'Neue Sorten fuer stabile Ernten',
    subtitle: 'Wie Selektion und Diversitaet die Lieferkette robuster machen.',
    readingTime: '8 Min',
    image: wissen5,
  },
  {
    category: 'Excelsa',
    title: 'Vom Feld bis zur Roestung: Excelsa Prozess',
    subtitle: 'Verarbeitungsschritte, die das Profil von Excelsa praegen.',
    readingTime: '5 Min',
    image: wissen6,
  },
];
---

<BaseLayout title="Wissen – HyCoffee">
  <Navigation />
  <main class="wissen">
    <div class="articles-grid">
      {articles.map((article) => (
        <article class="science-card">
          <span class="card-category">{article.category}</span>
          <div class="card-image">
            <Image src={article.image} alt={article.title} widths={[400, 800, 1200]} sizes="(min-width: 1600px) 33vw, (min-width: 1000px) 50vw, 100vw" format="webp" quality={72} loading="lazy" decoding="async" />
          </div>
          <h3 class="card-title">{article.title}</h3>
          <p class="card-subtitle">{article.subtitle}</p>
          <div class="card-footer">
            <div class="card-meta">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <circle cx="11" cy="11" r="10" stroke="#e3e2e0" stroke-width="1"></circle>
                <path d="M11 6v5l3 3" stroke="#e3e2e0" stroke-width="1" stroke-linecap="round"></path>
              </svg>
              <span>{article.readingTime}</span>
            </div>
            <a href="/wissen/klimawandel-kaffeeanbau" class="btn-tertiary">
              <span>Artikel lesen</span>
              <svg class="arrow" width="14" height="11" viewBox="0 0 14 11" fill="none">
                <path d="M1 5.5h12m0 0L8.5 1M13 5.5L8.5 10" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .wissen {
    background: var(--warm-grey-light);
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) !important;
    gap: 32px;
    padding: 64px 60px 60px;
  }

  @media (min-width: 1000px) and (max-width: 1599px) {
    .articles-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
  }

  @media (min-width: 1600px) {
    .articles-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    }
  }

  @media (max-width: 768px) {
    .articles-grid {
      gap: 16px;
      padding: 40px 12px 40px;
    }
  }

  .science-card {
    background: var(--warm-dark-grey);
    border-radius: var(--radius-card);
    padding: 40px 24px 20px;
    display: flex;
    flex-direction: column;
    min-height: 420px;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .card-category {
    font-family: var(--font-heading);
    font-size: var(--type-caption);
    line-height: 1.2;
    letter-spacing: 1.96px;
    text-transform: uppercase;
    font-weight: 400;
    color: #f0efed;
    margin-bottom: 16px;
  }

  .card-image {
    border-radius: var(--radius-nested);
    height: clamp(190px, 20vw, 280px);
    margin-bottom: 24px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Keep top/sides fully visible and fade out only toward the bottom. */
    -webkit-mask-image: linear-gradient(to bottom, #000 0 70%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 0 70%, transparent 100%);
    transition: transform 0.28s ease;
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: var(--type-card-title-mobile);
    line-height: 1.15;
    font-weight: 400;
    color: #f0efed;
    margin-bottom: 8px;
  }

  .card-subtitle {
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy);
    line-height: 1.3;
    color: #f0efed;
    margin-bottom: auto;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #f0efed;
    font-family: var(--font-heading);
    font-size: var(--type-hal-copy);
  }

  .btn-tertiary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--yellow);
    color: var(--warm-dark-grey);
    padding: 12px 24px 8px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-sm);
    line-height: 1;
    transition: opacity 0.2s;
  }

  .btn-tertiary:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
  }

  .arrow {
    width: 14px;
    height: 11px;
    transition: transform 0.2s ease;
  }

  @media (hover: hover) {
    .science-card:hover,
    .science-card:focus-within {
      transform: translateY(-4px);
      box-shadow: 0 12px 26px rgb(0 0 0 / 18%);
    }

    .science-card:hover .card-image img,
    .science-card:focus-within .card-image img {
      transform: scale(1.03);
    }

    .science-card:hover .arrow,
    .science-card:focus-within .arrow {
      transform: translateX(2px);
    }
  }
</style>
