</style>

<script is:inline>
  // Animate accordion rows slowly while keeping the clicked row anchored.
  document.querySelectorAll('.table-row-wrapper').forEach(wrapper => {
    const summary = wrapper.querySelector('summary.table-row');
    const details = wrapper.querySelector('.row-details');
    const duration = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 1 : 1000;
    const easing = 'cubic-bezier(0.16, 1, 0.3, 1)';
    if (!summary || !details) return;
    let activeAnimation = null;
    let activeDetailAnimation = null;

    function cleanup() {
      wrapper.style.height = '';
      wrapper.style.overflow = '';
      wrapper.classList.remove('is-animating');
      activeAnimation = null;
      activeDetailAnimation = null;
    }

    function keepSummaryAnchored(beforeTop) {
      const afterTop = summary.getBoundingClientRect().top;
      const delta = afterTop - beforeTop;
      if (delta === 0) return;
      const prev = document.documentElement.style.scrollBehavior;
      document.documentElement.style.scrollBehavior = 'auto';
      window.scrollBy(0, delta);
      document.documentElement.style.scrollBehavior = prev;
    }

    function animateRow(open) {
      if (activeAnimation) return;

      const beforeTop = summary.getBoundingClientRect().top;
      const startHeight = wrapper.offsetHeight;

      wrapper.style.height = `${startHeight}px`;
      wrapper.style.overflow = 'hidden';
      wrapper.classList.add('is-animating');
      wrapper.getBoundingClientRect();

      if (open) wrapper.open = true;

      const endHeight = open
        ? summary.offsetHeight + details.offsetHeight
        : summary.offsetHeight;

      activeDetailAnimation = details.animate(
        [
          {
            opacity: open ? 0 : 1,
            transform: open ? 'translateY(-6px)' : 'translateY(0)'
          },
          {
            opacity: open ? 1 : 0,
            transform: open ? 'translateY(0)' : 'translateY(-6px)'
          }
        ],
        {
          duration,
          easing,
          fill: 'both'
        }
      );

      activeAnimation = wrapper.animate(
        [
          { height: `${startHeight}px` },
          { height: `${endHeight}px` }
        ],
        {
          duration,
          easing,
          fill: 'both'
        }
      );

      activeAnimation.onfinish = () => {
        wrapper.open = open;
        if (activeDetailAnimation) activeDetailAnimation.cancel();
        cleanup();
        keepSummaryAnchored(beforeTop);
      };

      activeAnimation.oncancel = cleanup;
    }

    summary.addEventListener('click', event => {
      if (event.target.closest('button')) return;
      event.preventDefault();
      animateRow(!wrapper.open);
    });
  });

  document.querySelectorAll('.table-row-wrapper').forEach(wrapper => {
    wrapper.addEventListener('toggle', (e) => {
      if (!wrapper.classList.contains('is-animating')) return;
      e.stopPropagation();
    });
  });

  // Client preview switcher: alt = no-image offer, v1 = legacy image intro.
  (function () {
    const switcher = document.getElementById('shop-layout-switcher');
    if (!switcher) return;
    const options = Array.from(switcher.querySelectorAll('[data-shop-version]'));
    const STORAGE_KEY = 'hycoffee-shop-layout';
    const versions = ['alt', 'v1'];

    function apply(version) {
      const next = versions.includes(version) ? version : 'alt';
      document.body.classList.remove('shop-alt', 'shop-v1');
      document.body.classList.add(`shop-${next}`);
      options.forEach((option) => {
        const active = option.dataset.shopVersion === next;
        option.classList.toggle('is-active', active);
        option.setAttribute('aria-pressed', String(active));
      });

      if (next === 'alt') {
        document.querySelectorAll('.table-row-wrapper[open]').forEach((row) => {
          row.removeAttribute('open');
        });
      }
    }

    const saved = localStorage.getItem(STORAGE_KEY);
    apply(saved);

    options.forEach((option) => {
      option.addEventListener('click', () => {
        const next = option.dataset.shopVersion;
        if (!versions.includes(next)) return;
        localStorage.setItem(STORAGE_KEY, next);
        apply(next);
      });
    });
  })();

  (function () {
    const switcher = document.getElementById('shop-color-switcher');
    if (!switcher) return;
    const options = Array.from(switcher.querySelectorAll('[data-shop-color]'));
    const STORAGE_KEY = 'hycoffee-shop-offer-color';
    const colors = ['yellow', 'green', 'purple'];

    function apply(color) {
      const next = colors.includes(color) ? color : 'yellow';
      document.body.classList.remove('shop-color-yellow', 'shop-color-green', 'shop-color-purple');
      document.body.classList.add(`shop-color-${next}`);
      options.forEach((option) => {
        const active = option.dataset.shopColor === next;
        option.classList.toggle('is-active', active);
        option.setAttribute('aria-pressed', String(active));
      });
    }

    const saved = localStorage.getItem(STORAGE_KEY);
    apply(saved);

    options.forEach((option) => {
      option.addEventListener('click', () => {
        const next = option.dataset.shopColor;
        if (!colors.includes(next)) return;
        localStorage.setItem(STORAGE_KEY, next);
        apply(next);
      });
    });
  })();

  (function () {
    if (document.body.classList.contains('shop-alt') || document.body.classList.contains('shop-v1')) return;
    document.body.classList.add('shop-alt');
  })();

  (function () {
    if (document.body.classList.contains('shop-color-yellow') || document.body.classList.contains('shop-color-green') || document.body.classList.contains('shop-color-purple')) return;
    document.body.classList.add('shop-color-yellow');
  })();
</script>
