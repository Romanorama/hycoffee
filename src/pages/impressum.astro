---
import LegalPage from '../components/LegalPage.astro';
import { reader } from '../lib/cms';

export const prerender = true;

const data = await reader.singletons.impressum.read();
if (!data) throw new Error('Impressum singleton not found');
---

<LegalPage
  title="Impressum – HyCoffee"
  description="Rechtliche Anbieterkennzeichnung von HyCoffee."
  heading={data.heading}
  sections={data.sections}
  noindex={true}
/>
