---
import LegalPage from '../components/LegalPage.astro';
import { reader } from '../lib/cms';

export const prerender = true;

const data = await reader.singletons.datenschutz.read();
if (!data) throw new Error('Datenschutz singleton not found');
---

<LegalPage
  title="Datenschutz – HyCoffee"
  description="Informationen zur Verarbeitung personenbezogener Daten bei HyCoffee."
  heading={data.heading}
  sections={data.sections}
  noindex={true}
/>
