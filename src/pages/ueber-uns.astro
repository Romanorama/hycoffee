---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { reader, resolveCmsImage } from '../lib/cms';

export const prerender = true;

const data = await reader.singletons.ueberUns.read();
if (!data) throw new Error('Über-uns singleton not found');

const heroImage = resolveCmsImage(data.heroImage);
if (!heroImage) throw new Error(`Hero image not found: ${data.heroImage}`);

const stripImages = data.stripImages
  .map((path) => resolveCmsImage(path))
  .filter((img): img is NonNullable<typeof img> => img !== null);

const storyParagraphs = data.storyBody.split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);

const teamEntries = await reader.collections.team.all();
const teamMembers = teamEntries
  .map(({ entry }) => entry)
  .sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));

const telHref = (phone: string) => {
  const clean = phone.replace(/\s/g, '');
  if (clean.startsWith('+')) return `tel:${clean}`;
  if (clean.startsWith('0')) return `tel:+49${clean.slice(1)}`;
  return `tel:${clean}`;
};
---

<BaseLayout
  title="Über Uns – HyCoffee"
  description="Lerne das Team hinter HyCoffee kennen und erfahre, wie wir klimaresiliente Kaffees mit Forschung, Partnerschaften und direkter Zusammenarbeit voranbringen."
  ogImage={heroImage}
  ogImageAlt="Das HyCoffee Team"
>
  <Navigation />
  <main class="about">
    <div class="photo-strip">
      <div class="photo-strip-track">
        {[...stripImages, ...stripImages].map((img) => (
          <Image src={img} alt="" class="strip-img" widths={[200, 400]} sizes="200px" format="webp" quality={72} loading="lazy" decoding="async" />
        ))}
      </div>
    </div>

    <div class="about-split">
      <aside class="about-split-left">
        <Image src={heroImage} alt="Sophie und Charlotte" class="about-hero-img" widths={[600, 900, 1200]} sizes="(max-width: 768px) 100vw, 50vw" format="webp" quality={74} loading="lazy" decoding="async" />
        <div class="about-hero-left-inner">
          <p class="about-hero-text">{data.heroText}</p>
        </div>
      </aside>

      <div class="about-split-right">
        <section class="about-hero-right">
          <h2 class="about-headline">{data.storyHeading}</h2>
          {storyParagraphs.map((paragraph) => (
            <p class="about-body">{paragraph}</p>
          ))}
        </section>

        <section class="origins-banner">
          <p class="origins-banner-text">{data.originsBannerText}</p>
          <a href="/origins" class="btn-origins">
            <span>{data.originsBannerCtaLabel}</span>
            <svg class="arrow" width="14" height="11" viewBox="0 0 14 11" fill="none">
              <path d="M1 5.5h12m0 0L8.5 1M13 5.5L8.5 10" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </section>

        <section class="say-hy">
          <p class="say-hy-heading">{data.sayHiHeading}<br /><a href={`mailto:${data.sayHiEmail}`} class="say-hy-email">{data.sayHiEmail}</a></p>
        </section>

        <section class="contact-cards">
          {teamMembers.map((member, i) => (
            <div class={`contact-card ${i === 0 ? 'contact-card-yellow' : 'contact-card-green'}`}>
              <p class="contact-name">{member.name}</p>
              <a href={`mailto:${member.email}`} class="contact-detail">{member.email}</a>
              <a href={telHref(member.phone)} class="contact-detail">{member.phone}</a>
            </div>
          ))}
        </section>

        <a href="https://www.instagram.com/hycoffeeco/" target="_blank" rel="noopener noreferrer" class="social-link">Instagram</a>
        <a href="https://de.linkedin.com/company/hycoffee" target="_blank" rel="noopener noreferrer" class="social-link">LinkedIn</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .photo-strip {
    width: 100%;
    height: 100px;
    overflow: hidden;
    filter: grayscale(100%);
    border-bottom: 1px solid var(--warm-dark-grey);
    position: sticky;
    top: 84px;
    z-index: 5;
    margin-top: -1px;
  }

  .photo-strip-track {
    display: flex;
    height: 100%;
    gap: 0;
    animation: strip-scroll 40s linear infinite;
  }

  @keyframes strip-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .strip-img {
    height: 100%;
    width: auto;
    min-width: 180px;
    object-fit: cover;
    flex-shrink: 0;
    margin-right: -8px;
    transition: transform 0.6s ease, z-index 0s;
    position: relative;
    z-index: 1;
    border-right: 1px solid var(--warm-dark-grey);
  }

  .strip-img:hover {
    transform: scale(1.15);
    z-index: 10;
  }

  .about-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
  }

  .about-split-left {
    background: var(--green);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    position: sticky;
    top: 184px;
    height: calc(100vh - 184px);
    overflow: hidden;
    align-self: start;
    z-index: 1;
  }

  .about-split-right {
    display: flex;
    flex-direction: column;
    min-width: 0;
    container-type: inline-size;
    container-name: about-right;
    border-left: 1px solid var(--warm-dark-grey);
  }

  .about-hero-img {
    display: block;
    width: 100%;
    flex: 1 1 0;
    min-height: 0;
    object-fit: cover;
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .about-hero-left-inner {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 48px;
  }

  .about-hero-text {
    font-family: var(--font-heading);
    font-size: var(--type-statement-sm);
    line-height: 1.3;
    color: #f5f5f5;
    text-align: center;
    max-width: 700px;
    white-space: pre-line;
  }

  .about-hero-right {
    padding: clamp(36px, 4.2vw, 60px);
  }

  .about-headline {
    font-family: var(--font-heading);
    font-size: var(--type-statement);
    line-height: 1.1;
    color: var(--warm-dark-grey);
    margin: 0 0 24px;
    font-weight: 400;
  }

  .about-body {
    font-family: var(--font-heading);
    font-size: clamp(17px, 1.45vw, 20px);
    line-height: 1.3;
    color: var(--warm-dark-grey);
    margin-bottom: 16px;
  }

  .origins-banner {
    container-type: inline-size;
    background: var(--warm-grey-light);
    border-top: 1px solid var(--warm-dark-grey);
    border-bottom: 1px solid var(--warm-dark-grey);
    padding: clamp(32px, 3.8vw, 40px) clamp(28px, 5vw, 69px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(16px, 2vw, 24px);
  }

  .origins-banner-text {
    font-family: var(--font-heading);
    font-size: clamp(26px, 3vw, var(--type-statement));
    font-size: clamp(26px, 4.8cqw, var(--type-statement));
    line-height: 1.05;
    color: var(--warm-dark-grey);
    text-align: center;
    min-width: 0;
  }

  .btn-origins {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--warm-dark-grey);
    color: var(--white);
    padding: 16px 20px 6px;
    border-radius: var(--radius-control);
    font-family: var(--font-ui);
    font-size: var(--type-button-lg);
    line-height: 1;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .btn-origins:hover {
    filter: brightness(1.15);
    transform: scale(1.01);
    text-shadow: var(--button-text-hover-glow);
  }

  .arrow {
    width: 14px;
    height: 11px;
  }

  .say-hy {
    container-type: inline-size;
    background: var(--violet);
    padding: clamp(48px, 5vw, 64px) clamp(20px, 3vw, 36px);
    text-align: center;
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .say-hy-heading {
    font-family: var(--font-heading);
    font-size: clamp(34px, 3.6vw, var(--type-display-sm));
    font-size: clamp(34px, 7.2cqw, var(--type-display-sm));
    line-height: 0.95;
    letter-spacing: 0;
    font-weight: 400;
    color: var(--warm-dark-grey);
  }

  .say-hy-email {
    color: var(--warm-dark-grey);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 0.2s;
  }

  .say-hy-email:hover {
    opacity: 0.7;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    position: relative;
    background: var(--warm-dark-grey);
    border-bottom: 1px solid var(--warm-dark-grey);
  }

  .contact-cards::before {
    content: "";
    position: absolute;
    top: 15%;
    bottom: 15%;
    left: 50%;
    width: 1px;
    background: var(--white);
    transform: translateX(-0.5px);
    pointer-events: none;
  }

  .contact-card {
    container-type: inline-size;
    min-width: 0;
    padding: clamp(36px, 3.6vw, 48px) clamp(18px, 2.5vw, 48px);
    text-align: center;
  }

  .contact-card-yellow {
    background: var(--warm-dark-grey);
  }

  .contact-card-green {
    background: var(--warm-dark-grey);
  }

  .contact-card .contact-name,
  .contact-card .contact-detail {
    color: var(--white);
  }

  .contact-name {
    font-family: var(--font-heading);
    font-size: clamp(22px, 2.5vw, var(--type-statement));
    font-size: clamp(22px, 7.2cqw, var(--type-statement));
    line-height: 1.08;
    color: var(--white);
    margin-bottom: 4px;
  }

  .contact-detail {
    display: block;
    transition: opacity 0.2s;
    font-family: var(--font-heading);
    font-size: clamp(22px, 2.5vw, var(--type-statement));
    font-size: clamp(22px, 7.2cqw, var(--type-statement));
    line-height: 1.08;
    color: var(--white);
    white-space: nowrap;
  }

  .contact-detail:hover {
    opacity: 0.6;
  }

  .social-link {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(28px, 3vw, var(--type-statement));
    line-height: 1.05;
    color: var(--warm-dark-grey);
    text-align: center;
    padding: 40px;
    border-bottom: 1px solid var(--warm-dark-grey);
    transition: background 0.2s;
  }

  .social-link:hover {
    background: var(--warm-grey-light);
  }

  @media (max-width: 1180px) {
    .about-split {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    }

    .about-hero-left-inner {
      padding: 44px 30px;
    }

    .about-hero-text {
      font-size: clamp(24px, 2.45vw, var(--type-statement-sm));
      line-height: 1.24;
    }

    .origins-banner {
      flex-direction: column;
      text-align: center;
    }

  }

  @container about-right (max-width: 760px) {
    .origins-banner {
      flex-direction: column;
      text-align: center;
    }

    .contact-cards {
      grid-template-columns: 1fr;
    }

    .contact-cards::before {
      content: none;
    }

    .contact-card-yellow {
      border-right: none;
      position: relative;
    }

    .contact-card-yellow::after {
      content: "";
      position: absolute;
      right: 15%;
      bottom: 0;
      left: 15%;
      border-bottom: 1px solid var(--white);
    }

    .contact-name,
    .contact-detail {
      font-size: clamp(26px, 5.4cqw, var(--type-statement));
    }
  }

  @media (max-width: 980px) {
    .contact-name,
    .contact-detail {
      font-size: clamp(26px, 5vw, var(--type-statement));
    }
  }

  @media (max-width: 768px) {
    .photo-strip {
      height: 70px;
      top: calc(var(--nav-height, 50px) - 4px);
    }

    .strip-img {
      min-width: 120px;
    }

    .about-split {
      display: block;
    }

    .about-split-left {
      position: static;
      height: auto;
      overflow: visible;
    }

    .about-hero-img {
      flex: 0 0 auto;
      height: auto;
    }

    .about-hero-left-inner {
      padding: 56px 20px 32px;
    }

    .about-hero-text {
      font-size: var(--type-copy-intro);
      line-height: 1.3;
      max-width: none;
    }

    .about-hero-right {
      padding: 32px 20px;
      text-align: left;
    }

    .about-body {
      font-size: var(--type-hal-copy);
      line-height: 1.55;
      margin-bottom: 14px;
    }

    .origins-banner {
      padding: 28px 20px;
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }

    .origins-banner-text {
      font-size: var(--type-banner-mobile);
      line-height: 1.2;
    }

    .btn-origins {
      font-size: var(--type-button);
      padding: 9px 18px;
    }

    .say-hy {
      padding: 40px 20px;
    }

    .contact-cards {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .contact-cards::before {
      content: none;
    }

    .contact-card {
      padding: 32px 20px;
    }

    .contact-card-yellow {
      border-right: none;
      position: relative;
    }

    .contact-card-yellow::after {
      content: "";
      position: absolute;
      right: 15%;
      bottom: 0;
      left: 15%;
      border-bottom: 1px solid var(--white);
    }

    .contact-name,
    .contact-detail {
      font-size: var(--type-statement-mobile);
      line-height: 1.25;
    }

    .social-link {
      font-size: var(--type-statement-mobile);
      line-height: 1.2;
      padding: 24px 20px;
    }
  }
</style>
